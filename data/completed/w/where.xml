      <Meanings>
        <Meaning id="bcbb1bd6-be12-4193-9b74-a57e3be8421c" type="Adverb">
          <Vi>ở đâu, nơi nào</Vi>
          <En>Used to ask about or indicate the place or location of something or someone.</En>
          <Example>Where is the nearest subway station?</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="efd78e5e-bc83-481f-904b-a8ebdd6fc177">
              <Vi>Đặt câu hỏi để tìm hiểu vị trí của một địa điểm.</Vi>
              <En>Asking to find out the location of a place.</En>
            </Situation>
            <Situation id="ae3f1e9b-60ff-4372-9b7c-c38379bf1ec4">
              <Vi>Chỉ định vị trí trong câu trần thuật (mang nghĩa gián tiếp).</Vi>
              <En>Indicating location in an indirect statement (e.g., “I don’t know where he went”).</En>
            </Situation>
