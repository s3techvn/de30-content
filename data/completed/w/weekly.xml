      <Meanings>
        <Meaning id="495acb29-72a1-4509-a844-07315465c082" type="Adjective">
          <Vi>Hàng tuần; hàng bảy ngày</Vi>
          <En>Occurring or published once every week.</En>
          <Example>The company holds a weekly staff meeting every Monday morning.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="8f755d4f-0b54-4a11-aa82-04c3a06c5bf5">
              <Vi>Mô tả sự kiện, ấn phẩm, hoặc hoạt động diễn ra định kỳ mỗi tuần.</Vi>
              <En>Describing an event, publication, or activity that recurs every seven days.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="9db86efa-88e8-43bb-98a0-cc509693ba0f" type="Noun">
          <Vi>Tạp chí/tuần báo</Vi>
          <En>A publication that is issued once a week.</En>
          <Example>She reads *The Economist* weekly to stay updated on global economics.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="8e01ea84-2d4c-4d04-b7da-1ef7c7b7b8da">
              <Vi>Dùng để chỉ các ấn phẩm định kỳ hàng tuần, đặc biệt là báo chí.</Vi>
              <En>Used to refer to periodical publications released on a weekly basis, especially news magazines.</En>
            </Situation>
          </Situations>
        </Meaning>
