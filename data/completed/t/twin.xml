      <Meanings>
        <Meaning id="40b20b44-59c2-4273-b39f-7bf7ec67c3e4" type="Noun">
          <Vi>song sinh</Vi>
          <En>One of two offspring born at the same birth from the same pregnancy.</En>
          <Example>They are identical twins who look exactly alike.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="ec042b82-6bd3-405a-bba3-f88d0689486a">
              <Vi>Trường hợp một người mẹ sinh hai bé cùng lúc.</Vi>
              <En>A situation where a mother gives birth to two babies simultaneously.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="c0cacc69-2f4d-487e-9f40-f9a9ba56e878" type="Verb">
          <Vi>sinh đôi</Vi>
          <En>To give birth to twins.</En>
          <Example>The couple’s second child was twin-born, but they say it was a surprise!</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="2c9b3433-a7ae-4237-8db3-07cac89885ed">
              <Vi>Mô tả hành động sinh hai con cùng lúc.</Vi>
              <En>Describing the act of delivering two babies in one birth.</En>
            </Situation>
          </Situations>
