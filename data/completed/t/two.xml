          <En>The cardinal number occurring after one and before three.</En>
          <Example>I have two apples in my bag.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="f350ae26-e1bc-49a1-8ce0-962faad18060">
