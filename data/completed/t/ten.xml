      <Meanings>
        <Meaning id="ac14d932-feb0-4b15-9c4e-65772749872c" type="Noun">
          <Vi>Mười</Vi>
          <En>The cardinal number equal to 10.</En>
          <Example>There are ten apples in the basket.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="bab0c8e7-0663-4d94-bdbe-589d6251fa1b">
              <Vi>Số lượng đếm được khi cộng thêm một đơn vị vào chín.</Vi>
              <En>The quantity obtained by adding one to nine.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="17695ff3-9c2b-49d9-a0ae-03bd9864650f" type="Adjective">
          <Vi>Mười (dùng để chỉ số lượng)</Vi>
          <En>Denoting a quantity consisting of 10 items or units.</En>
          <Example>She scored ten points in the game.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="6abd8391-697b-4cf6-a6ed-8b1cbb570d39">
              <Vi>Mô tả số lượng cụ thể của vật hoặc người.</Vi>
              <En>Used to specify the exact number of items or people.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="a4a03f17-b9be-4efc-9e44-1a9a6fe9831f" type="Noun">
          <Vi>Mười (trong hệ thập phân)</Vi>
          <En>The base of the decimal number system.</En>
          <Example>Each digit in a decimal number represents a power of ten.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="02f08ea5-e2db-4288-b89f-95a3c33b30ff">
              <Vi>Cơ sở của hệ đếm thập phân, dùng trong toán học và khoa học.</Vi>
              <En>The foundation of the decimal numeral system, used in mathematics and science.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
