      <Meanings>
        <Meaning id="fa86aef8-ead6-48cb-8104-bf9736856312" type="Noun">
          <Vi>thuế nhập khẩu; biểu thuế</Vi>
          <En>A tax imposed on imports or exports, especially one used to raise revenue or protect domestic industries.</En>
          <Example>The government announced a new tariff on steel imports to support local manufacturers.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="65484bff-c2c6-4b05-ad16-e331a1b898e8">
              <Vi>Chính phủ áp thuế bổ sung vào hàng nhập khẩu để bảo vệ ngành sản xuất trong nước.</Vi>
              <En>A government imposes additional taxes on imported goods to protect domestic industries.</En>
            </Situation>
            <Situation id="f8c9f7fb-b669-4243-a347-f6c7a4495acd">
              <Vi>Biểu thuế được công bố hàng năm để điều chỉnh dòng hàng hóa qua biên giới.</Vi>
              <En>A tariff schedule is published annually to regulate the flow of goods across borders.</En>
            </Situation>
          </Situations>
        </Meaning>
