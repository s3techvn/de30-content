          <Vi>giấy chứng nhận, chứng chỉ</Vi>
          <En>A document that attests to the truth of a fact, qualification, or status.</En>
          <Example>She received a certificate of completion after finishing the online course.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="a7e15ce4-7dae-4c21-a91d-2a87dc365be3">
