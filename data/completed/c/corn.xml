      <Meanings>
        <Meaning id="0ed199c8-1851-4aec-b9bb-cf0aad7c0520" type="Noun">
          <Vi>Ngô (ngô ngọt, bắp ngô)</Vi>
          <En>A cereal plant that produces large grains, or cobs, usually yellow or white, used as food for humans and animals.</En>
          <Example>She boiled a few ears of corn for dinner.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="dd2cbe11-33d1-45b1-8507-c30ac4592a03">
              <Vi>Mô tả việc trồng, thu hoạch, hoặc ăn ngô (bắp).</Vi>
              <En>Contexts involving growing, harvesting, or eating corn (e.g., at a barbecue or in a soup).</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="049c7f1c-8b00-4bd1-a553-54880daafd21" type="Noun">
          <Vi>Ngô (dạng bột hoặc bột ngô – Mỹ)</Vi>
          <En>Finely ground dried corn kernels, used in cooking or as animal feed.</En>
          <Example>He added a spoonful of cornmeal to the batter.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="8fdba795-aa21-437b-89aa-3c9b46c3d138">
              <Vi>Sử dụng bột ngô trong nấu ăn hoặc chăn nuôi.</Vi>
              <En>Contexts involving cornmeal in recipes or livestock feed.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
