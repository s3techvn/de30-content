      <Meanings>
        <Meaning id="67eb5958-f265-4d9b-98c6-7517333ddd38" type="Noun">
          <Vi>Con trỏ (máy tính)</Vi>
          <En>A marker on a computer screen that indicates the position where the next character will be inserted or the location of the mouse pointer.</En>
          <Example>Move the cursor to the text box and click to begin typing.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="e5d6d48c-2f40-44d2-9ae0-2d0dd31f3160">
              <Vi>Người dùng điều khiển con trỏ chuột để chọn hoặc nhập dữ liệu.</Vi>
              <En>The user moves the mouse cursor to select or input data on screen.</En>
            </Situation>
            <Situation id="3b96ca24-220f-4c1f-ae10-58fc6550b4ae">
              <Vi>Trong soạn thảo văn bản, con trỏ nhấp nháy cho biết vị trí chèn văn bản.</Vi>
              <En>In word processing, the blinking cursor shows where text will be inserted.</En>
            </Situation>
          </Situations>
