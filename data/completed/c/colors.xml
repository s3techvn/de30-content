      <Meanings>
        <Meaning id="f2df975e-4f7a-41a6-875d-6a50fed94493" type="Noun">
          <Vi>màu sắc</Vi>
          <En>The property of an object that depends on the light it reflects, emits, or transmits, typically perceived as red, blue, green, etc.</En>
          <Example>The artist carefully chose the colors for her painting to evoke a sense of calm.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="b6f1c9ad-d719-4316-a3a2-18277c506e76">
              <Vi>Mô tả các sắc thái thị giác trong nghệ thuật hoặc thiết kế.</Vi>
              <En>Describing visual hues in art, design, or nature.</En>
            </Situation>
            <Situation id="5cbf01d0-e3e9-4d2a-a632-c34dc7fe68f5">
              <Vi>Chọn màu để phối đồ hoặc trang trí nội thất.</Vi>
              <En>Selecting hues for clothing or interior decoration.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="458bdc08-e961-47e6-9538-dff57f6681cd" type="Noun">
          <Vi>màu nhuộm; phẩm màu</Vi>
          <En>Substances used to add color to materials such as fabric, food, or hair.</En>
          <Example>The fabric was dyed using natural colors derived from plants.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="b6df8011-1173-476c-bf7f-5292437a6770">
              <Vi>Sử dụng phẩm màu trong công nghiệp dệt may.</Vi>
              <En>Using dyes in textile manufacturing.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
