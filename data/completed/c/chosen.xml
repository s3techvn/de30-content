      <Meanings>
        <Meaning id="4b352f05-0904-44ee-9b45-f7890ee63aea" type="Adjective">
          <Vi>được chọn; được tuyển chọn</Vi>
          <En>Selected or picked out from a group or pool of candidates; not random or accidental.</En>
          <Example>She was the chosen candidate for the scholarship.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="7683a53f-4eb1-4cde-bda9-8735c7bfa508">
              <Vi>Trong bối cảnh tuyển chọn ứng viên cho một vị trí hoặc giải thưởng.</Vi>
              <En>Used when referring to someone selected for a specific role, award, or opportunity after evaluation.</En>
            </Situation>
            <Situation id="e89789c4-2a4b-4272-88e8-f4b2b6d538c1">
              <Vi>Trong ngữ cảnh tôn giáo hoặc thiêng liêng (ví dụ: dân được Chúa chọn).</Vi>
              <En>Used in religious contexts to denote a group or individual selected by divine will (e.g., "the chosen people").</En>
            </Situation>
          </Situations>
        </Meaning>
