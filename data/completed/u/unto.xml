      <Meanings>
        <Meaning id="fa7cc8ae-b5c6-438c-acd3-1e3bffa2d084" type="Preposition">
          <Vi>tới, đến, cho (tương đương với "to" trong tiếng Anh hiện đại)</Vi>
          <En>To (used in archaic, poetic, or religious contexts to express direction, recipient, or relation).</En>
          <Example>Render unto Caesar the things which are Caesar's.</Example>
        </Meaning>
        <Meaning id="9cc105fe-664f-4882-a54f-43fb26711187" type="Preposition">
          <Vi>cho đến, cho tới (tương đương với "until")</Vi>
          <En>Until (up to a particular time or event).</En>
          <Example>He remained faithful unto death.</Example>
        </Meaning>
      </Meanings>
