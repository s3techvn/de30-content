      <Meanings>
        <Meaning id="a092e0c6-b3ce-4e79-a5a6-504723f8e51f" type="Noun">
          <Vi>Bản tin; thông cáo; bảng thông báo</Vi>
          <En>A short official report or notice, especially one issued regularly by a government, organization, or news agency.</En>
          <Example>The weather service released a severe storm bulletin at noon.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="9dcc255f-99b4-453b-bdd0-f21baad5c736">
              <Vi>Cơ quan chức năng phát hành bản tin cập nhật tình hình thiên tai.</Vi>
              <En>Authorities issue a bulletin updating the public on a natural disaster.</En>
            </Situation>
            <Situation id="9ddcd9b9-a454-4aa3-a7d6-2477c60bf91e">
