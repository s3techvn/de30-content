      <Meanings>
        <Meaning id="7ae04f98-df7c-4330-aeaa-32c40f962bc6" type="Adjective">
          <Vi>thứ cấp; thứ hai; phụ</Vi>
          <En>being of a lower rank, importance, or quality; secondary to something else</En>
          <Example>She put her career on hold to focus on her secondary responsibility: raising her children.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="8d04f3f3-dcb9-4891-980d-8f8551c2cda5">
              <Vi>Mô tả mức độ ưu tiên thấp hơn một yếu tố chính.</Vi>
              <En>Describes something that has lower priority or importance compared to a primary factor.</En>
            </Situation>
            <Situation id="3846e57e-4973-49f9-96ec-0043ae87096c">
              <Vi>Chỉ cấp học hoặc trình độ học vấn thấp hơn (ví dụ: trung học cơ sở, trung học phổ thông).</Vi>
              <En>Refers to a lower level of education (e.g., middle school, high school).</En>
            </Situation>
