      <Meanings>
        <Meaning id="dd1e4b86-2943-4374-a39a-e561d277dace" type="Noun">
          <Vi>Mùa hè</Vi>
          <En>The season between spring and autumn, typically the warmest time of the year.</En>
          <Example>Many people go to the beach during the summer.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="b9881511-c4e0-494b-bb68-7edf48d704a2">
              <Vi>Thời tiết nắng nóng, học sinh nghỉ hè, cây cối xanh tốt.</Vi>
              <En>Hot weather, school holidays, lush green vegetation.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="852d6e2b-982f-4dfd-a32b-4deae7f66429" type="Verb">
          <Vi>Nghỉ hè; tăng trưởng mạnh vào mùa hè (đối với một số loài sinh vật)</Vi>
          <En>To spend the summer; to grow or increase rapidly during the summer months.</En>
          <Example>The tomato plants summer quickly in the warm sun.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="37b1fd13-5357-4fd1-b87d-14429e5acc48">
              <Vi>Nhân viên nghỉ phép dài ngày trong tháng 6–8.</Vi>
              <En>Employees take extended leave from June to August.</En>
            </Situation>
          </Situations>
        </Meaning>
