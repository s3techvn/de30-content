        <Meaning id="dcf935bd-93bb-4c8a-970c-b4fc80944cae" type="Adjective">
          <Vi>Nghiêm trọng, khốc liệt, dữ dội</Vi>
          <En>Very serious, intense, or harsh, especially in a way that causes great difficulty or suffering.</En>
          <Example>The patient was admitted with severe chest pain.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="2e3938c1-056a-4c0b-9298-23e4d9b34912">
              <Vi>Mô tả tình trạng bệnh nặng hoặc tai nạn nghiêm trọng.</Vi>
              <En>Describing a serious medical condition or serious accident.</En>
            </Situation>
            <Situation id="20abd0a2-53aa-401d-bd6b-0e1f0bb3c877">
              <Vi>Mô tả thời tiết khắc nghiệt như bão, lũ lụt.</Vi>
              <En>Describing harsh weather conditions such as storms or floods.</En>
            </Situation>
            <Situation id="e9426cfd-09cf-475b-ab98-a13590322603">
              <Vi>Mô tả hình phạt hoặc hậu quả nghiêm trọng.</Vi>
              <En>Describing a harsh punishment or serious consequence.</En>
            </Situation>
          </Situations>
