      <Meanings>
        <Meaning id="454d2ba0-6f44-4e28-8028-1dd99374bd95" type="Adjective">
          <Vi>đẹp tuyệt vời, gây choáng ngợp</Vi>
          <En>extremely beautiful, impressive, or attractive in a way that causes surprise or admiration</En>
          <Example>She looked absolutely stunning in her red evening gown.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="61abd853-f84d-4d7d-8de3-65cd256b3e00">
              <Vi>Mô tả vẻ đẹp gây ấn tượng mạnh, thường dùng để khen ngoại hình hoặc trang phục nổi bật.</Vi>
              <En>Used to praise someone’s striking appearance, especially in fashion or formal events.</En>
            </Situation>
            <Situation id="8caa318f-0774-461a-b905-0fdc996380aa">
              <Vi>Mô tả cảnh vật, sự kiện hoặc tác phẩm nghệ thuật gây kinh ngạc vì độ hoành tráng hoặc tinh tế.</Vi>
              <En>Used to describe scenery, events, or artworks that are breathtakingly impressive.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
