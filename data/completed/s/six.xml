        <Meaning id="803f7702-0e7f-4856-a8b3-b6d4f3bbd6ba" type="Noun">
          <Vi>sáu</Vi>
          <En>The natural number following five and preceding seven.</En>
          <Example>She has six apples in her basket.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="423cdbc3-e871-40d1-82f3-a60e6e127efe">
              <Vi>Đếm số lượng vật thể hoặc người.</Vi>
              <En>Counting physical objects or people.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="90ce3b56-9b30-4e74-b096-f79c03e23692" type="Adjective">
          <Vi>sáu</Vi>
          <En>Denoting a quantity of six.</En>
          <Example>We waited for six hours.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="6fc72091-4c86-4bab-89d4-6c3fc86e4c86">
              <Vi>Mô tả số lượng trong câu, thường đứng trước danh từ.</Vi>
              <En>Describing quantity in a sentence, typically preceding a noun.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="e9cc2022-5040-4e8d-986c-6b4a4a856cd0" type="Noun">
