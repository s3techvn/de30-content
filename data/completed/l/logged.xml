      <Meanings>
        <Meaning id="6fd60fa2-e89f-4223-94fd-2fde28995496" type="Adjective">
          <Vi>đã được ghi lại</Vi>
          <En>Recorded or stored in a log, typically for tracking or auditing purposes.</En>
          <Example>The system logged all user access attempts for security review.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="07be6afc-39e6-4c77-9062-2422d23c5805">
              <Vi>Mô tả trạng thái của dữ liệu hoặc hành động đã được ghi vào hệ thống.</Vi>
              <En>Describes the state of data or an action that has been recorded in a system.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="277d25c6-98d0-4200-930b-c8d1d4ae7d32" type="Verb">
          <Vi>đã ghi (vào nhật ký)</Vi>
          <En>Past tense and past participle of "log"; to record information in a logbook or digital system.</En>
          <Example>She logged her hours before submitting the timesheet.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="7b1647ad-17a3-47b7-b7a0-004228b34c86">
              <Vi>Hành động ghi lại thời gian làm việc, hoạt động, hoặc sự kiện vào hệ thống.</Vi>
              <En>The action of recording work hours, activities, or events into a system.</En>
            </Situation>
          </Situations>
        </Meaning>
