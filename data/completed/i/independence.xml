        <Meaning id="fb8b5156-6bcd-4ca4-b954-b034fb2c03cb" type="Noun">
          <Vi>Độc lập</Vi>
          <En>The state of being independent, especially free from outside control or influence; self-governance.</En>
          <Example>The declaration of independence marked the formal separation of the colonies from British rule.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="e4c24569-e40f-475f-b5b4-6180bca0e649">
