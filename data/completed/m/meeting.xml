      <Meanings>
        <Meaning id="b6463550-b342-40db-91ab-efc1b2e46ac5" type="Noun">
          <Vi>Họp, cuộc họp</Vi>
          <En>A formal or informal gathering of people, typically for a specific purpose such as discussion, decision-making, or information exchange.</En>
          <Example>We have a team meeting every Monday at 10 a.m.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="e839a6a9-dab2-4a24-890d-a6c16936c54b">
              <Vi>Các đồng nghiệp tụ tập để thảo luận về tiến độ dự án.</Vi>
              <En>Colleagues gather to discuss project progress.</En>
            </Situation>
            <Situation id="321787cd-1416-48d3-8a05-1b8b35357825">
              <Vi>Học sinh tham gia buổi họp phụ huynh với giáo viên.</Vi>
              <En>Students attend a parent-teacher conference.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="2d376f60-4b39-4497-9e32-36b8b2b67645" type="Noun">
          <Vi>Sự gặp gỡ, cuộc gặp</Vi>
          <En>An occasion when two or more people meet, especially for a planned purpose.</En>
          <Example>The two leaders held a secret meeting to discuss the treaty.</Example>
