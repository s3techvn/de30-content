      <Meanings>
        <Meaning id="7885f0d4-cc95-4d10-aa73-4ed09e2a8f80" type="Noun">
          <Vi>chuyên ngành (danh từ)</Vi>
          <En>a main academic subject that a student specializes in.</En>
          <Example>She changed her major from chemistry to physics.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="edd7ca4c-900b-4b20-a0ca-a4ed13421583">
              <Vi>Dùng khi nói về việc chọn hoặc thay đổi chuyên ngành học.</Vi>
              <En>Used when discussing selecting or changing a student’s primary field of study.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="886f2760-b4cd-438a-999a-c33e5acd537b" type="Noun">
          <Vi>hàng lớn (trong thương mại)</Vi>
          <En>the main or principal amount in a financial transaction, as opposed to interest or fees.</En>
          <Example>The bond pays interest on the major.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="8e00bacb-844e-44c8-a9c3-111fc700ed0b">
              <Vi>Dùng trong ngữ cảnh tài chính để chỉ vốn gốc (không tính lãi).</Vi>
              <En>Used in finance to refer to the principal sum, excluding interest or additional charges.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
