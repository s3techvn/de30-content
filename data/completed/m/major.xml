      <Meanings>
        <Meaning id="1d4bf8d9-3996-4ba5-9276-e9bca560a9c2" type="Adjective">
          <Vi>chính, quan trọng, lớn</Vi>
          <En>more important, serious, or significant than others of the same kind.</En>
          <Example>She has a major role in the film.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="5e5f76cf-3dd8-406c-a00c-39f47b3d58d0">
              <Vi>Mô tả một vấn đề, vai trò, hoặc yếu tố có mức độ quan trọng cao.</Vi>
              <En>Describing an issue, role, or factor that holds high importance or impact.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="2daa1b48-d091-49ef-95ce-d5e5d9749fb1" type="Adjective">
          <Vi>chuyên ngành (dùng trong học đường)</Vi>
          <En>the main field of study at a university, especially one chosen by a student.</En>
          <Example>He is a biology major.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="9157c885-fa53-40d4-ba5d-14627c663365">
              <Vi>Dùng để nói về chuyên ngành học của sinh viên đại học.</Vi>
              <En>Used to refer to a student’s primary academic discipline at university.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
    </Pronunciation>
    <Pronunciation id="98bfdf7b-cc87-4632-ae8d-7c4df8800f7f" ipa="/ˈmeɪ.dʒər/" vi_ipa="mê-gơ">
