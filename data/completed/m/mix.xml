      <Meanings>
        <Meaning id="7176005e-3972-428b-9aaf-c5bcc4c8f974" type="Verb">
          <Vi>trộn, pha trộn</Vi>
          <En>To combine two or more substances together, typically so that they are no longer separate.</En>
          <Example>She mixed flour, eggs, and milk to make pancake batter.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="485c7ce6-30df-49f7-8e99-c9f1775a440e">
              <Vi>Thao tác kết hợp các nguyên liệu trong nấu ăn hoặc pha chế.</Vi>
              <En>The action of combining ingredients while cooking or mixing drinks.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="09c5b312-0b24-415e-98cc-d835b8b686fa" type="Noun">
          <Vi>sự trộn, hỗn hợp</Vi>
          <En>A combination of different elements or things.</En>
          <Example>The soil was a rich mix of compost and sand.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="cbe82ff3-0b76-447f-bf1b-192ec14a5fdf">
              <Vi>Mô tả một hỗn hợp gồm nhiều thành phần khác nhau (ví dụ: đất, màu sơn, người trong nhóm).</Vi>
              <En>Describing a combination of diverse components (e.g., soil, paint, people in a group).</En>
            </Situation>
          </Situations>
        </Meaning>
