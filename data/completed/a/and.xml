      <Meanings>
        <Meaning id="ec10df4a-c2f0-43ba-812d-08dd5d1c6a79" type="Conjunction">
          <Vi>và (được phát âm rõ ràng hơn khi nhấn mạnh hoặc ở cuối câu)</Vi>
          <En>Used in formal or emphatic speech, especially at the end of a list or for emphasis.</En>
          <Example>He likes tea, coffee, and.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="807d156d-7b06-41dd-b4da-a770e0230548">
              <Vi>Dùng khi nhấn mạnh hoặc trong văn phong trang trọng, thường ở cuối danh sách.</Vi>
              <En>Used for emphasis or in formal contexts, especially before the final item in a list (Oxford comma context).</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
    </Pronunciation>
