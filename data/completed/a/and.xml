      <Meanings>
        <Meaning id="67bd7fa4-258c-4a36-a5dd-ca7e6a4ef656" type="Conjunction">
          <Vi>và</Vi>
          <En>Used to connect words, phrases, clauses, or sentences that are related or added together.</En>
          <Example>She bought apples and oranges.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="569221f4-5476-4691-b8ef-77a97ff8fd19">
              <Vi>Dùng để nối hai hoặc nhiều từ, cụm từ, mệnh đề có cùng vai trò trong câu.</Vi>
              <En>Used to join two or more words, phrases, or clauses of equal grammatical status.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
    </Pronunciation>
    <Pronunciation id="8e862ddf-79cc-424b-851a-786261308432" ipa="/ænd/" vi_ipa="ép-đờ">
