      <Meanings>
        <Meaning id="7809591c-77e5-4dad-83a5-22396ba6e482" type="Noun">
          <Vi>Khán giả; thính giả; người xem; người nghe</Vi>
          <En>A group of people assembled to watch, listen to, or attend a performance, speech, or other event.</En>
          <Example>The audience clapped enthusiastically after the final act.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="bed40a3e-1d24-4665-a5a5-003f25d4c272">
              <Vi>Người xem một vở kịch, buổi hòa nhạc, hoặc buổi thuyết trình.</Vi>
              <En>People watching a play, concert, or lecture.</En>
            </Situation>
            <Situation id="02860088-0ec6-402b-85e9-424564caae61">
              <Vi>Người xem một chương trình truyền hình hoặc video trực tuyến.</Vi>
              <En>People watching a TV show or online video.</En>
