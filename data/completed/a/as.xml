      <Meanings>
        <Meaning id="f9f5b442-5fe3-49cc-bc25-7ccc28b763eb" type="Preposition">
          <Vi>như, như là</Vi>
          <En>used to indicate that something has the same identity, quality, or function as something else.</En>
          <Example>She works as a teacher.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="79699065-1bd3-49c9-a072-325f5354e2a5">
              <Vi>Mô tả vai trò, chức năng, hoặc bản chất tương đương.</Vi>
              <En>Used to describe role, function, or equivalent nature.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="4f307399-c792-44ac-b0b9-3afcdf85cfeb" type="Conjunction">
          <Vi>khi, trong khi, vì, như là</Vi>
          <En>used to introduce a clause indicating time, cause, or comparison.</En>
          <Example>As I was walking, it started to rain.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="501018fd-0797-4630-aa23-fb8df9b93c51">
              <Vi>Chỉ thời gian đồng thời hoặc nguyên nhân.</Vi>
              <En>Indicates simultaneous time or cause.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="90c207fd-c70d-4875-afa4-a0d965f5dd11" type="Adverb">
          <Vi>đến mức, như vậy</Vi>
          <En>used to introduce a comparison or degree.</En>
          <Example>He is not as tall as his brother.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="e99b9f49-5071-41fb-b148-934a956c9066">
              <Vi>Dùng trong cấu trúc so sánh ngang bằng.</Vi>
              <En>Used in equative comparison structures.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
    </Pronunciation>
