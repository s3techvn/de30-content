      <Meanings>
        <Meaning id="5e25f39a-4863-4da2-95b4-734520a3fba1" type="Noun">
          <Vi>Quỹ đạo</Vi>
          <En>The path described by one object in its regular course around another object, especially a planet or satellite around a star or planet.</En>
          <Example>The Moon completes one orbit around Earth approximately every 27.3 days.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="279109ca-5ca9-4d00-9de9-5da0c2455806">
              <Vi>Mô tả đường đi của vệ tinh quanh Trái Đất.</Vi>
              <En>Describing the path of a satellite circling Earth.</En>
            </Situation>
            <Situation id="c02fe941-0a9d-48cf-8a23-78c5ec0205e9">
              <Vi>Chuyển động đều đặn của hành tinh quanh mặt trời.</Vi>
              <En>The regular movement of a planet around the Sun.</En>
            </Situation>
          </Situations>
        </Meaning>
