      <Meanings>
        <Meaning id="714a5c45-86d0-4b1c-b21c-7ae409d62732" type="Adjective">
          <Vi>miệng; bằng miệng</Vi>
          <En>Relating to or involving the mouth; expressed or communicated without writing, especially spoken.</En>
          <Example>The doctor examined her oral cavity during the checkup.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="578944cf-9e56-415e-8929-dbed2ce896e7">
              <Vi>Mô tả các vấn đề liên quan đến miệng, như sâu răng, viêm lợi, hoặc kiểm tra nha khoa.</Vi>
              <En>Used when describing conditions, procedures, or issues related to the mouth, such as dental exams or oral hygiene.</En>
            </Situation>
            <Situation id="606e5598-a44e-4b7b-b980-a89898beaae3">
              <Vi>Mô tả bài kiểm tra hoặc bài thuyết trình được thực hiện bằng lời nói thay vì viết.</Vi>
              <En>Used to describe assessments or presentations delivered verbally rather than in writing, such as oral exams or oral reports.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
