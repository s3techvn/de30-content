      <Meanings>
        <Meaning id="2a61ca58-13c8-4641-8289-cf7de1ab7278" type="Noun">
          <Vi>Nhóm</Vi>
          <En>A number of people or things that are located, gathered, or classified together.</En>
          <Example>We formed a study group to prepare for the exam.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="7a59141f-90e5-49bd-84c1-fb600a9a40ff">
              <Vi>Một tập hợp người cùng làm việc, học tập, hoặc chia sẻ đặc điểm chung.</Vi>
              <En>A collection of individuals who interact, collaborate, or share common characteristics.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="3739a8b9-0e11-454a-9ca4-4ae75ffffb2c" type="Verb">
          <Vi>Nhóm lại; xếp thành nhóm</Vi>
          <En>To put or arrange (things or people) into a group or groups.</En>
          <Example>The teacher grouped the students by age and skill level.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="c21ddd2d-d262-4678-85e6-73437f67adac">
              <Vi>Hành động phân loại hoặc sắp xếp đối tượng theo từng nhóm để dễ quản lý hoặc phân tích.</Vi>
              <En>The act of categorizing or organizing items or individuals into clusters for efficiency or analysis.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
