      <Meanings>
        <Meaning id="adb3a465-0170-4c42-91d5-66761e964040" type="Noun">
          <Vi>giám mục quản lý hồ sơ; nhân viên hành chính trường học</Vi>
          <En>A person responsible for maintaining official records, especially in a university or court.</En>
          <Example>The university registrar handles student enrollment and grade reporting.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="fbe8944a-9558-407b-93ab-81954a778d64">
              <Vi>Học sinh đến văn phòng giám mục để đăng ký môn học hoặc xin bảng điểm.</Vi>
              <En>A student visits the registrar's office to register for classes or request transcripts.</En>
            </Situation>
            <Situation id="7ce8fc0f-7bec-4600-9f4d-500201f22a70">
              <Vi>Giám mục tổ chức và lưu trữ hồ sơ của các vụ án trong tòa án.</Vi>
              <En>The court registrar organizes and maintains records of legal proceedings.</En>
            </Situation>
          </Situations>
        </Meaning>
