      <Meanings>
        <Meaning id="8fbe6cce-2706-48d5-b951-31b974692fff" type="Adjective">
          <Vi>giữ kín, kín đáo, dè dặt, không biểu lộ cảm xúc</Vi>
          <En>not showing one’s feelings or opinions; restrained or formal in manner</En>
          <Example>She gave a reserved nod and said little during the meeting.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="98922fa5-210f-4b5d-9b25-2daef12d653a">
              <Vi>Mô tả người không dễ bộc lộ cảm xúc, thường gặp trong giao tiếp xã hội.</Vi>
              <En>Describes someone who does not easily express emotions, commonly observed in social interactions.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="73bc0b43-6842-455c-b90e-9f02e39a52d3" type="Adjective">
          <Vi>đã đặt trước (giường, ghế, vé…)</Vi>
          <En>arranged in advance and held for a particular person or purpose</En>
          <Example>We have a reserved table for two at 8 p.m.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="3cf7b031-77fe-477b-9f72-77436e981a97">
              <Vi>Tình huống đặt trước chỗ ngồi, phòng khách sạn, hoặc vé xem phim.</Vi>
              <En>Scenario involving advance booking of seats, hotel rooms, or movie tickets.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
