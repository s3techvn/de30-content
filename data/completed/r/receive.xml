      <Meanings>
        <Meaning id="b3a2bc70-0b37-4636-ba53-5bad1e90a256" type="Verb">
          <Vi>nhận, đón nhận</Vi>
          <En>To get or be given something, especially something offered or expected.</En>
          <Example>I received a gift from my friend on my birthday.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="1ef4085a-23fe-4fd7-823a-0e91b8e17833">
              <Vi>Đón nhận vật phẩm, thư từ, hoặc thông tin từ người khác.</Vi>
              <En>Accepting physical items, letters, or information from someone else.</En>
            </Situation>
            <Situation id="647fc2ee-4b60-4c6c-86e4-2c09122abdd8">
              <Vi>Chấp nhận một lời đề nghị, lời mời, hoặc lời chúc.</Vi>
              <En>Accepting an offer, invitation, or greeting.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="d41565d1-dd57-4ca8-baf2-934afff9c877" type="Verb">
          <Vi>tiếp đón, đón tiếp</Vi>
          <En>To welcome or greet someone, especially in a formal or official capacity.</En>
          <Example>The host received the guests warmly at the door.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="e68834d5-dd8f-4bcb-8827-73a266030984">
              <Vi>Đón tiếp khách đến nhà hoặc sự kiện.</Vi>
              <En>Welcoming guests arriving at a home or event.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
