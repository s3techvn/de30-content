      <Meanings>
        <Meaning id="24f2b6c5-a6f0-4099-83bd-e5c551a45265" type="Adjective">
          <Vi>thuộc Nga, thuộc người Nga</Vi>
          <En>belonging to Russia or its people, language, or culture</En>
          <Example>She studied Russian literature at university.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="34e67071-fe21-4e6f-9c92-645fcfad3f42">
              <Vi>Mô tả điều gì liên quan đến nước Nga, người Nga, hoặc văn hóa Nga.</Vi>
              <En>Used to describe anything related to Russia, its people, or its culture.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
