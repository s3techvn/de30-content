      <Meanings>
        <Meaning id="66cdd790-2892-4b25-a4fd-d562d253dedf" type="Noun">
          <Vi>người Nga</Vi>
          <En>a native or citizen of Russia</En>
          <Example>The Russian spoke fluent English after living in London for five years.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="ee4da096-6c55-4ec3-8dfe-b60c7e339992">
              <Vi>Dùng để chỉ một cá nhân có quốc tịch hoặc nguồn gốc từ Nga.</Vi>
              <En>Used to refer to an individual from Russia, especially by nationality or ethnicity.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="1a8faaa3-949b-4e77-b0fb-64287c267957" type="Noun">
          <Vi>ngôn ngữ Nga</Vi>
          <En>the Slavic language spoken as the official language of Russia and widely in other former Soviet republics</En>
          <Example>He is learning Russian to read Dostoevsky in the original.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="23673b3b-a6f0-415a-9abd-33efeb7ea8e0">
              <Vi>Dùng để chỉ tiếng Nga như một ngôn ngữ được học hoặc sử dụng.</Vi>
              <En>Used when referring to the Russian language as an object of study or communication.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
