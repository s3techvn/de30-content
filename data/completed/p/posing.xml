        <Meaning id="9a79ca61-cd4c-4d23-a3df-ee6c1ad5121d" type="Verb">
          <Vi>giả tạo, tạo dáng, làm dáng</Vi>
          <En>to assume a particular posture, especially for artistic or photographic purposes, or to behave in a way that is insincere or intended to impress others</En>
          <Example>She spent ten minutes posing for the portrait before the artist was satisfied.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="c9c0fcb1-8849-4077-96ef-eabf36dc5e48">
