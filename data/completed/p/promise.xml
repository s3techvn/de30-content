      <Meanings>
        <Meaning id="b58aa67a-4a3f-40f1-8e9e-3587cba5ffef" type="Verb">
          <Vi>Hứa, hứa hẹn</Vi>
          <En>To commit oneself to doing something; to give one’s word.</En>
          <Example>She promised to call me as soon as she arrived.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="fc08334c-3f50-4c32-84c9-d1dfbde9104a">
              <Vi>Người nói bảo đảm sẽ làm điều gì đó cho người khác.</Vi>
              <En>The speaker assures someone else that they will do something.</En>
            </Situation>
            <Situation id="c202fc10-2083-4916-92da-9438ef8da133">
              <Vi>Đưa ra lời hứa trong hợp đồng hoặc thỏa thuận chính thức.</Vi>
              <En>Making a formal commitment in a contract or agreement.</En>
            </Situation>
          </Situations>
        </Meaning>
