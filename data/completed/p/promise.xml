      <Meanings>
        <Meaning id="c92bd8e0-e01a-4f60-bd9c-7f92599d8200" type="Noun">
          <Vi>Lời hứa</Vi>
          <En>A commitment or agreement to do something or to act in a certain way.</En>
          <Example>I made a promise to my friend that I would help her move next weekend.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="97cfef7d-6032-47e5-ada6-895f57986797">
              <Vi>Người nói cam kết sẽ thực hiện điều gì đó trong tương lai.</Vi>
              <En>The speaker commits to performing something in the future.</En>
            </Situation>
            <Situation id="a6504648-18d5-4454-8d5e-8e16862da285">
              <Vi>Việc giữ hoặc vi phạm lời hứa trong quan hệ cá nhân hoặc công việc.</Vi>
              <En>Keeping or breaking a promise in personal or professional relationships.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
    </Pronunciation>
    <Pronunciation id="c118f351-3648-4a12-a255-7f6746fb9ad4" ipa="/prəˈmɪs/" vi_ipa="pờ-rờ-mít">
