      <Meanings>
        <Meaning id="e5e04435-3ae3-4c3e-87af-00a947ecc453" type="Noun">
          <Vi>Ngày trả lương</Vi>
          <En>The day on which employees receive their wages or salary.</En>
          <Example>My payday is every other Friday, so I always plan my big purchases around it.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="fa93b8f7-96ba-49ff-b8de-c5a4494ab4e3">
              <Vi>Ngày người lao động nhận tiền lương từ chủ hoặc công ty.</Vi>
              <En>The date when workers receive their compensation from their employer.</En>
            </Situation>
            <Situation id="cd51d891-f61c-4512-ba8e-78f38191a29a">
              <Vi>Thời điểm gần ngày nhận lương, nhiều người chi tiêu nhiều hơn.</Vi>
              <En>The period just before or after receiving a paycheck, often associated with increased spending.</En>
            </Situation>
          </Situations>
        </Meaning>
