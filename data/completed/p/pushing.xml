        <Meaning id="1bccbfed-6749-41be-9039-2f858f83deee" type="Verb">
          <Vi>đẩy, thúc đẩy</Vi>
          <En>to exert force on something to move it away from oneself or its current position</En>
          <Example>She was pushing the shopping cart down the aisle.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="377e3d66-1fb3-48cb-aeed-a97a8f37d3e6">
