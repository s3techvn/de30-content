      <Meanings>
        <Meaning id="c0f814e3-907b-477d-ba78-18e821f84017" type="Adjective">
          <Vi>Ngoài trời; bên ngoài, thuộc về mặt ngoài</Vi>
          <En>Being on the outside or surface of something; not interior.</En>
          <Example>The exterior of the house was painted white.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="fd5458fb-2663-4244-9d53-1bd39e67fe78">
              <Vi>Mô tả hình thức bên ngoài của một công trình, vật thể.</Vi>
              <En>Describing the outer appearance or surface of a building or object.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="a1471352-8b99-4e8b-afd5-e8215b270578" type="Noun">
          <Vi>Mặt ngoài; bề mặt bên ngoài</Vi>
          <En>The outer surface or side of something, especially a building.</En>
          <Example>The architect focused on the exterior design to improve curb appeal.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="c667a463-f2ef-4b3c-883b-32564806b214">
              <Vi>Thảo luận về vật liệu, màu sơn, hoặc trạng thái của mặt ngoài công trình.</Vi>
              <En>Discussing materials, paint, or condition of a building’s outer surface.</En>
            </Situation>
          </Situations>
        </Meaning>
