      <Meanings>
        <Meaning id="a6f173ba-3236-4dc7-a387-6fb6257c9f0f" type="Noun">
          <Vi>Người thám hiểm</Vi>
          <En>A person who travels to unknown or unfamiliar places, especially to explore and discover new lands, cultures, or scientific information.</En>
          <Example>Christopher Columbus was a famous explorer who crossed the Atlantic Ocean in 1492.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="9817f609-792a-4917-9091-faa1642097b3">
