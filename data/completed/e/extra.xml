      <Meanings>
        <Meaning id="cf98753b-3008-4f07-b735-0cdd11b47289" type="Adjective">
          <Vi>thêm, phụ, dự phòng</Vi>
          <En>additional; extra, beyond what is usual or necessary</En>
          <Example>We ordered the main dish and an extra side of fries.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="d623b56c-1060-4f4c-bc42-45f0fb868e92">
              <Vi>Chỉ vật hoặc dịch vụ được cung cấp thêm ngoài tiêu chuẩn hoặc yêu cầu cơ bản.</Vi>
              <En>Refers to something provided beyond the standard or basic requirement.</En>
            </Situation>
            <Situation id="dee8203b-8dd6-4421-9112-76c880475d85">
              <Vi>Thường dùng khi đề cập đến chi phí bổ sung (ví dụ: phí extra cho hành lý quá cước).</Vi>
              <En>Often used when referring to additional charges (e.g., extra fee for overweight luggage).</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
