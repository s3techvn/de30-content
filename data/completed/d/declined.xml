      <Meanings>
        <Meaning id="fa029186-c42d-4910-ac60-4db81fd00d93" type="Verb">
          <Vi>khước từ, từ chối</Vi>
          <En>To refuse or reject something offered, especially politely or formally.</En>
          <Example>She politely declined the invitation to the wedding.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="ef717f47-16b1-41cf-8d9c-5d37bb7a4816">
              <Vi>Một người từ chối lời mời hoặc đề nghị một cách lịch sự.</Vi>
              <En>A person politely refuses a request, invitation, or offer.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="7ea1fd7b-7046-424c-8b63-14ff1776d0f7" type="Verb">
          <Vi>giảm, suy giảm (về số lượng, giá trị, mức độ)</Vi>
          <En>To become less in amount, value, or strength; to decrease.</En>
          <Example>The company's profits declined by 15% last quarter.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="94891b92-13c1-4a03-9de7-0059ce039ade">
              <Vi>Mô tả sự giảm sút về số lượng, giá trị, hoặc mức độ.</Vi>
              <En>Describing a reduction in quantity, value, or intensity over time.</En>
            </Situation>
          </Situations>
        </Meaning>
