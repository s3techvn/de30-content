      <Meanings>
        <Meaning id="e385c45f-404e-49fc-991d-6185cf79676d" type="Adjective">
          <Vi>Bẩn, dơ, không sạch sẽ</Vi>
          <En>Not clean; covered or marked with an unclean substance.</En>
          <Example>Don't touch the clean walls with your dirty hands.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="54b6f5b8-fe12-4012-88dd-d42a38902e5e">
              <Vi>Nói về quần áo, tay chân hoặc đồ vật bị bám bẩn</Vi>
              <En>Describing clothes, hands, or objects covered in dirt</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="7f3fdfa9-c9b0-4c48-8b63-9b840d097692" type="Adjective">
          <Vi>Gian lận, không trung thực, chơi xấu</Vi>
          <En>Dishonest, unfair, or unsporting.</En>
          <Example>He is known for playing dirty tricks on his competitors.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="0242288d-6f8f-4d7f-9237-fbbab7c18e9c">
              <Vi>Mô tả hành vi chơi xấu trong thể thao hoặc kinh doanh</Vi>
              <En>Describing unfair behavior in sports or business</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="2b22e2e9-5139-484c-a701-e658e570b6d0" type="Verb">
          <Vi>Làm bẩn, làm dơ</Vi>
          <En>To make something dirty.</En>
          <Example>The kids dirtied their clothes playing in the mud.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="a8502e36-0662-4750-ad6b-091d92ec6967">
              <Vi>Khi ai đó làm dơ quần áo hoặc đồ đạc</Vi>
              <En>When someone makes clothes or furniture unclean</En>
            </Situation>
          </Situations>
        </Meaning>
