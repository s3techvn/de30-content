      <Meanings>
        <Meaning id="fc3fe77d-e820-4ec8-ba96-9098f804378e" type="Verb">
          <Vi>khám phá; phát hiện</Vi>
          <En>to find (something or someone) unexpectedly or in the course of a search</En>
          <Example>Galileo discovered the moons of Jupiter using a telescope.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="e71e34e0-f028-48b7-b090-89e82fb3e992">
              <Vi>Một nhà khoa học tìm ra một hiện tượng tự nhiên mới.</Vi>
              <En>A scientist finds a new natural phenomenon.</En>
            </Situation>
            <Situation id="482c7a1f-70e3-4ec8-87e6-80d73584b307">
              <Vi>Tôi vô tình phát hiện ra một lỗi trong phần mềm.</Vi>
              <En>I accidentally discovered a bug in the software.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="bca1bee3-06e1-409b-968f-3f3c72ddc1e2" type="Verb">
          <Vi>biết được; nhận ra (thông tin, sự thật)</Vi>
          <En>to learn or become aware of new information or a fact</En>
          <Example>She discovered that her keys had been under her pillow all along.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="20007973-474a-4a54-9b99-05dd9b9a184e">
              <Vi>Tôi vừa mới biết được rằng anh ấy đã từ chức.</Vi>
              <En>I just discovered that he had resigned.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
