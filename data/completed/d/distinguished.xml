      <Meanings>
        <Meaning id="dbf5aaf2-d398-47d4-a06c-255e20682b91" type="Adjective">
          <Vi>đáng kính trọng; uy tín; nổi bật</Vi>
          <En>highly respected or accomplished, especially in a professional or public capacity; standing out as superior in quality or character.</En>
          <Example>She is a distinguished professor of history at Harvard University.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="9c888963-aa25-4204-bfda-05f93e6e191e">
              <Vi>Mô tả một người có thành tựu xuất sắc và được xã hội tôn trọng.</Vi>
              <En>Used to describe a person with notable achievements and high social or professional standing.</En>
            </Situation>
            <Situation id="b2a5df7f-50c6-4ffb-95a4-790ec46d4087">
              <Vi>Dùng để chỉ một đặc điểm làm nổi bật một cá nhân hoặc vật so với những người/vật khác.</Vi>
              <En>Used to highlight a feature that sets someone or something apart as exceptional.</En>
            </Situation>
          </Situations>
