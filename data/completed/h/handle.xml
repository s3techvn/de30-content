      <Meanings>
        <Meaning id="96da9797-3a5d-443d-9513-345228fbd0f7" type="Verb">
          <Vi>Điều khiển, xử lý, quản lý</Vi>
          <En>To manage or deal with something, especially a situation or responsibility</En>
          <Example>She handled the crisis calmly and efficiently.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="46fe42df-ec5a-4858-bb1f-b447bcdc58cb">
              <Vi>Tình huống một người chịu trách nhiệm giải quyết một vấn đề khó khăn.</Vi>
              <En>A person takes charge of resolving a difficult issue.</En>
            </Situation>
            <Situation id="714c3863-988f-4b60-8b84-124c296852b6">
              <Vi>Tình huống một người điều khiển hoặc thao tác một công cụ, thiết bị.</Vi>
              <En>A person operates or controls a tool or device.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="9b516d41-2ec5-4494-b441-5a0a3a9b3f68" type="Noun">
          <Vi>Cầm, tay cầm</Vi>
          <En>A part of an object designed to be held or grasped, such as a door handle or kettle handle</En>
          <Example>He turned the handle to open the door.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="ea150a1b-8f4c-44ff-93b4-5b1d573630ec">
              <Vi>Tình huống sử dụng tay cầm để mở cửa, bật công tắc, hoặc mang vác vật.</Vi>
              <En>Using a handle to open a door, switch on a device, or carry an item.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
