      <Meanings>
        <Meaning id="5c113f0c-498b-4b67-9974-d5c84bac4b22" type="Verb">
          <Vi>Cầm, nắm, giữ (bằng tay)</Vi>
          <En>To hold or grip something, especially with the hand</En>
          <Example>Can you handle the pot with oven mitts?</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="e6bd6eac-419f-4fcd-9038-33579d908cba">
              <Vi>Tình huống cầm nắm vật nóng hoặc nặng một cách an toàn.</Vi>
              <En>Grasping a hot or heavy object safely, e.g., while cooking.</En>
            </Situation>
          </Situations>
        </Meaning>
