        <Meaning id="db929700-153c-4086-a831-e0c894f620cc" type="Noun">
          <Vi>khách sạn</Vi>
          <En>A building where people can pay to stay temporarily, typically offering rooms, meals, and other services.</En>
          <Example>They booked a suite at a luxury hotel in Paris for their anniversary trip.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
