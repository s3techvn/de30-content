    <Pronunciation id="57b0c2da-472b-4825-840b-624b4b5f41d1" ipa="/ˈɑː.pə.zət/" vi_ipa="ác-pơ-zớt">
      <Audios>
        <Audio type="male_normal" value="./male_normal.mp3" />
        <Audio type="male_slow" value="./male_slow.mp3" />
        <Audio type="female_normal" value="./female_normal.mp3" />
