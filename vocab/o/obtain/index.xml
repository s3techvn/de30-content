      <Meanings>
        <Meaning id="02fce92c-b13e-4081-ab57-51592735635f" type="Verb">
          <Vi>nhận được, có được (thông qua nỗ lực hoặc yêu cầu)</Vi>
          <En>to get or acquire something, especially through effort or request</En>
          <Example>She managed to obtain a scholarship after months of application.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="79563485-93b7-4206-8cfd-a5017e3d3dd2">
              <Vi>Yêu cầu hoặc tìm cách có được một vật phẩm, thông tin, hoặc cơ hội.</Vi>
              <En>Asking for or making efforts to acquire an item, information, or opportunity.</En>
            </Situation>
            <Situation id="30897cc5-a826-488f-95da-d0dcaa47559b">
              <Vi>Đạt được điều gì đó mong muốn sau khi đấu tranh hoặc chờ đợi.</Vi>
              <En>Achieving something desired after struggle or waiting.</En>
