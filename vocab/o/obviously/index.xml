        <Meaning id="d9e86bf4-ef87-44ce-ac03-689395a3f311" type="Adverb">
          <Vi>Rõ ràng, rõ ràng là, hiển nhiên</Vi>
          <En>In a way that is clearly true or easy to see; without doubt.</En>
          <Example>It was obviously a mistake—no one could have missed it.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="56bb17d4-edb9-44d9-a5ce-82c3bdcc55d7">
