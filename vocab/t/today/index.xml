      <Meanings>
        <Meaning id="bd53702e-3006-4509-8355-83b59fd01214" type="Noun">
          <Vi>hôm nay</Vi>
          <En>The current day; the day on which one is speaking or writing.</En>
          <Example>I have a meeting scheduled for today at 3 p.m.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="210fac3b-8718-4b92-a464-79cb5e4ce905">
              <Vi>Thời điểm hiện tại trong ngày, thường dùng để chỉ các sự kiện đang diễn ra hoặc dự kiến trong ngày.</Vi>
              <En>Refers to the present day, used to describe current or planned events happening now.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="a2fe2a45-874c-485c-8889-108b636f460d" type="Adverb">
          <Vi>hôm nay; trong ngày nay</Vi>
          <En>On this day; in the present day.</En>
          <Example>We decided to finish the project today.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="2640e902-a72f-4568-8c39-c8210b695f11">
              <Vi>Dùng để chỉ thời gian xảy ra hành động trong ngày hiện tại.</Vi>
              <En>Used to indicate that an action occurs on the current day.</En>
