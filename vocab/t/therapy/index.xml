      <Meanings>
        <Meaning id="f0717d2e-4b0b-4118-b301-9798f150a2d2" type="Noun">
          <Vi>liệu pháp; trị liệu</Vi>
          <En>A treatment intended to relieve or heal a disorder or illness, especially psychological or physical.</En>
          <Example>She began cognitive behavioral therapy to manage her anxiety.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="a589192e-e879-4207-a50a-e1cc6bb5d62a">
              <Vi>Bệnh nhân bắt đầu liệu pháp tâm lý sau khi chấn thương tinh thần.</Vi>
              <En>The patient started psychological therapy after a mental trauma.</En>
            </Situation>
            <Situation id="281ecbbd-402e-4c71-a79e-874242b41d01">
              <Vi>Vật lý trị liệu giúp phục hồi vận động sau tai biến.</Vi>
              <En>Physical therapy helps restore mobility after a stroke.</En>
            </Situation>
