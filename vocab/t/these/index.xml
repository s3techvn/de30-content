      <Meanings>
        <Meaning id="a96ae6a5-bb93-421a-bbd1-3ff3e1d563e8" type="Determiner">
          <Vi>Những này (dùng để chỉ người/vật ở gần người nói, số nhiều)</Vi>
          <En>Used to refer to two or more people or things that are close to the speaker.</En>
          <Example>These shoes are too tight.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="d07b90ee-9e9e-44f8-895a-de00aa7d8c04">
              <Vi>Chỉ các vật đang ở trong tay hoặc ngay trước mặt người nói.</Vi>
              <En>Referring to objects physically near the speaker, such as items on a table or in hand.</En>
            </Situation>
            <Situation id="35c09783-1906-48c0-a048-b967114799d4">
              <Vi>Dùng trong so sánh hoặc phân biệt với các vật ở xa (those).</Vi>
              <En>Used to contrast with "those," which refer to items farther away.</En>
            </Situation>
          </Situations>
        </Meaning>
