      <Meanings>
        <Meaning id="8435db7f-2b7b-4e44-bb4f-6ab0492c2a70" type="Adverb">
          <Vi>sau đó, lúc đó, rồi</Vi>
          <En>At that time; next; afterward.</En>
          <Example>First we’ll eat dinner, and then we’ll go to the movies.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="88492daf-8433-4b82-bc89-7633aa2a6cd5">
              <Vi>Mô tả trình tự sự việc trong quá khứ hoặc tương lai.</Vi>
              <En>Used to indicate the order of events in time.</En>
            </Situation>
            <Situation id="2e7c0c75-f2fe-4f12-9768-67465cf35e59">
              <Vi>Dùng trong hướng dẫn, công thức, hoặc lập trình để chỉ bước tiếp theo.</Vi>
              <En>Used in instructions, recipes, or programming to indicate the next step.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="4911e342-85e4-4f1c-827a-5ed475b4f18a" type="Adverb">
          <Vi>nếu vậy, như vậy thì</Vi>
          <En>In that case; given that; therefore.</En>
          <Example>If it rains, then we’ll stay inside.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="19420c62-55bf-492a-ae7f-f1190d1607dc">
              <Vi>Dùng để rút ra kết luận từ một điều kiện đã nêu.</Vi>
              <En>Used to draw a conclusion from a stated condition.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="1af91715-e6fd-46b1-aec5-e7ab7a414541" type="Adverb">
          <Vi>bấy giờ, thời điểm đó</Vi>
          <En>At that time; in the past; formerly.</En>
          <Example>He was a doctor then, but now he’s retired.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="b4d39833-6fde-49ee-b0a1-1229b3625647">
              <Vi>Dùng để so sánh hiện tại với quá khứ.</Vi>
              <En>Used to contrast the present with a past state.</En>
            </Situation>
          </Situations>
        </Meaning>
