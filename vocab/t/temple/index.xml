      <Meanings>
        <Meaning id="4c03ecbf-2105-487b-9cf7-83558322a7ce" type="Noun">
          <Vi>đền, chùa, đền thờ</Vi>
          <En>A building dedicated to the worship of a deity or deities; a place of religious worship.</En>
          <Example>The ancient temple in Angkor Wat attracts millions of visitors each year.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="49b32918-0cfa-4ed2-9e17-fb97528f1c65">
              <Vi>Người dân địa phương cầu nguyện và dâng lễ tại ngôi đền cổ mỗi ngày.</Vi>
              <En>Local people pray and offer sacrifices at the ancient temple every day.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="c2c64565-2373-439d-80bd-c393f91adbfe" type="Noun">
          <Vi>hố chẩm (phần đầu bên thái dương)</Vi>
          <En>The hollow area on either side of the forehead, above the eyes.</En>
          <Example>She massaged her temples to relieve the tension headache.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="232edd43-d26a-47aa-aacc-6fd3209e8187">
              <Vi>Cô ấy cảm thấy đau đầu và dùng ngón tay day nhẹ vào hai bên hố chẩm.</Vi>
              <En>She felt a headache and gently pressed her fingers against the sides of her temples.</En>
            </Situation>
          </Situations>
        </Meaning>
