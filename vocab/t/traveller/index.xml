      <Meanings>
        <Meaning id="828e7404-d3fe-42f3-b10b-063d9fe0dd90" type="Noun">
          <Vi>Người du hành; người đi du lịch</Vi>
          <En>A person who is travelling or has returned from a journey.</En>
          <Example>As a frequent traveller, she always packs a compact first-aid kit.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="b1c07d6e-02db-448e-acce-1fa3f0e93871">
              <Vi>Mô tả người đang đi du lịch hoặc vừa trở về từ một chuyến đi xa.</Vi>
              <En>Describing someone currently on a trip or who has just returned from one.</En>
            </Situation>
            <Situation id="d5b76909-67e6-4aba-a720-52c9f8a4dda6">
              <Vi>Dùng trong ngữ cảnh văn chương hoặc trang trọng để chỉ người đi xa.</Vi>
              <En>Used in literary or formal contexts to refer to someone on a journey.</En>
            </Situation>
          </Situations>
        </Meaning>
