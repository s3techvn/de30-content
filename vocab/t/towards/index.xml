      <Meanings>
        <Meaning id="07ab1c42-44bd-41c8-b1bc-a9c6ef509808" type="Preposition">
          <Vi>hướng về, về phía</Vi>
          <En>in the direction of; aiming or moving in the direction of something or someone</En>
          <Example>She walked towards the park after work.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="cf6e1a93-4eca-4f10-8fc3-b6f07e9e8326">
              <Vi>Mô tả hành động di chuyển hoặc hướng về một địa điểm cụ thể.</Vi>
              <En>Describes physical movement or orientation toward a specific location.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="6699749b-ce3c-47c2-a16c-b1c068554e36" type="Preposition">
          <Vi>hướng tới, nhằm vào (mục tiêu, tương lai, thái độ)</Vi>
          <En>aiming or directed toward a goal, future event, or attitude</En>
          <Example>His efforts are towards improving customer satisfaction.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="bd756686-61aa-4065-9a5d-d42c4f0ea0d0">
              <Vi>Dùng khi nói về nỗ lực, kế hoạch, hoặc cảm xúc hướng đến một mục tiêu trừu tượng.</Vi>
              <En>Used when referring to efforts, plans, or emotions directed toward an abstract goal or outcome.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
