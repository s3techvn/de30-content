      <Meanings>
        <Meaning id="314b5860-ab32-40ae-85ad-378b0779fc13" type="Verb">
          <Vi>Đặt tên cho; phong tước hiệu</Vi>
          <En>To give a title to a work; to confer a title or rank on someone</En>
          <Example>The committee voted to title the new policy “Green Future.”</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="e8160e9f-955e-4207-b7ee-0c34ebd9753c">
              <Vi>Đặt tên cho một tác phẩm nghệ thuật hoặc văn học</Vi>
              <En>To assign a name or heading to a creative or scholarly work</En>
            </Situation>
            <Situation id="b36bb5cd-e82b-430b-b5c6-6fa6dbf2480f">
              <Vi>Phong tước hiệu cho một cá nhân (thường trong nghi lễ)</Vi>
              <En>To officially confer a title or rank, especially in formal or ceremonial contexts</En>
            </Situation>
          </Situations>
