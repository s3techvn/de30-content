      <Meanings>
        <Meaning id="9374da4d-968f-4ef5-8318-aa68353bb3b0" type="Noun">
          <Vi>Tựa đề; danh hiệu; quyền sở hữu</Vi>
          <En>A name given to a book, film, article, or other creative work; a honorific or legal right to possess something</En>
          <Example>The movie’s title is *Inception*.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="6b2ee5ee-34a3-46e2-87b4-8d1279c097e7">
              <Vi>Tựa đề của một cuốn sách hoặc bài báo</Vi>
              <En>The heading or name assigned to a publication or article</En>
            </Situation>
            <Situation id="f5d864ae-de51-42d0-9e76-d341a5c30d40">
              <Vi>Danh hiệu quý tộc hoặc quyền sở hữu tài sản</Vi>
              <En>A legal right to ownership, especially of land or property</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
