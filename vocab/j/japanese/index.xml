      <Meanings>
        <Meaning id="ef98e47a-4d63-48eb-8968-deaeff6c0170" type="Adjective">
          <Vi>Thuộc về Nhật Bản; người Nhật</Vi>
          <En>Belonging to or associated with Japan or its people, language, or culture.</En>
          <Example>She enjoys learning Japanese calligraphy.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="5d3a79a6-725c-4d10-9299-42c7b2fd7157">
              <Vi>Mô tả đặc điểm, sản phẩm, hoặc con người liên quan đến Nhật Bản.</Vi>
              <En>Used to describe things originating from Japan, such as food, art, or people.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="a1f17b69-adef-40de-bfaa-1b49a9586ff3" type="Noun">
          <Vi>Ngôn ngữ tiếng Nhật; người Nhật</Vi>
          <En>The language spoken in Japan, or a native or citizen of Japan.</En>
          <Example>He studies Japanese at university.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="369b7266-5857-4249-a68d-ab191a4e5633">
              <Vi>Trong ngữ cảnh học ngoại ngữ hoặc nói về dân tộc.</Vi>
              <En>Used when referring to the Japanese language or Japanese people collectively.</En>
            </Situation>
          </Situations>
        </Meaning>
