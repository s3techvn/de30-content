      <Meanings>
        <Meaning id="34a7100f-b5a5-4d4e-bf8f-7934c0a4cdc6" type="Adjective">
          <Vi>Đủ điều kiện; hợp lệ; xứng đáng được hưởng (quyền, lợi ích)</Vi>
          <En>Meeting the required conditions or qualifications; legally qualified or suitable for a particular role, position, or benefit.</En>
          <Example>She is eligible to vote in the upcoming election.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="d59dd6f7-54f8-47fc-b3b0-4f2b5d2b44f6">
              <Vi>Người đáp ứng đủ tuổi, quốc tịch và các điều kiện pháp lý để bỏ phiếu.</Vi>
              <En>A person who meets the age, citizenship, and legal requirements to cast a ballot.</En>
            </Situation>
            <Situation id="799d51d2-2075-427b-a2bd-5bb2aa5f0f54">
              <Vi>Sinh viên đạt điểm và điều kiện đầu vào để nhập học chương trình đại học.</Vi>
              <En>A student who meets the academic and admission requirements for university enrollment.</En>
            </Situation>
