      <Meanings>
        <Meaning id="b83c1d7d-8369-46ba-a805-c951f9f09817" type="Adjective">
          <Vi>vĩnh hằng; bất diệt</Vi>
          <En>lasting forever; forever and ever; without end</En>
          <Example>They pledged their love in an eternal bond.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="f5ca17d3-546c-43a1-8bf8-d9cf28d2a685">
              <Vi>Mô tả điều tồn tại mãi mãi, không bao giờ kết thúc, thường dùng trong văn chương, tôn giáo, hoặc triết học.</Vi>
              <En>Used to describe something that exists forever, with no beginning or end—common in religious, philosophical, or poetic contexts.</En>
            </Situation>
            <Situation id="20586fd8-e1f3-4b5d-9327-e54e524210aa">
              <Vi>Mô tả cảm xúc hoặc cam kết kéo dài mãi mãi, như tình yêu hay lời thề.</Vi>
              <En>Used for enduring feelings or commitments, such as eternal love or eternal vows.</En>
            </Situation>
          </Situations>
