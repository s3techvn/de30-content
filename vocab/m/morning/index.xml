      <Meanings>
        <Meaning id="a1198cd9-a32f-4fc4-8272-ef8c5bb700da" type="Noun">
          <Vi>buổi sáng</Vi>
          <En>The time from sunrise to noon; the early part of the day.</En>
          <Example>She always drinks coffee right after waking up in the morning.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="4e088e4e-06eb-44c7-a9d5-7b99e17692b7">
              <Vi>Mô tả thời gian từ khi mặt trời mọc đến trước trưa.</Vi>
              <En>Describes the period from sunrise until noon.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="0edc6e28-a760-453c-a48f-9a628068e513" type="Noun">
          <Vi>buổi sáng đầu tiên (sau một sự kiện tiêu cực)</Vi>
          <En>The first day or period after a difficult event, often used metaphorically.</En>
          <Example>It was a dark morning after the storm of bad news.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="74ab5b73-13bc-4fe3-8c04-1a524e924bd4">
              <Vi>Dùng ẩn dụ để chỉ thời điểm khởi đầu sau một biến cố khó khăn.</Vi>
              <En>Used metaphorically to describe the beginning of a recovery or new phase after hardship.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
