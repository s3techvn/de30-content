      <Meanings>
        <Meaning id="f92d97ba-5abb-4d51-9bf0-d9eb14239155" type="Adjective">
          <Vi>không bóng, mờ, không phản xạ ánh sáng</Vi>
          <En>having a surface with little or no shine; not shiny or glossy.</En>
          <Example>The wall was painted in a matt white to reduce glare.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="45c059a0-4958-47a4-9249-29ca615091f5">
              <Vi>Mô tả bề mặt sơn, giấy, hoặc vải không bóng.</Vi>
              <En>Describing surfaces such as paint, paper, or fabric that lack shine.</En>
            </Situation>
            <Situation id="c8b88235-83ba-47b0-81be-5bfbe941df71">
              <Vi>So sánh với bề mặt bóng (glossy) trong thiết kế đồ họa.</Vi>
              <En>Contrasting with glossy finishes in graphic design or printing.</En>
            </Situation>
          </Situations>
        </Meaning>
