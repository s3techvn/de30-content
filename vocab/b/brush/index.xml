      <Meanings>
        <Meaning id="09a858ee-4796-40ae-b00a-be87c758c856" type="Verb">
          <Vi>Đánh bay, quét sạch (nhanh)</Vi>
          <En>To deal with something quickly and efficiently, often in a dismissive or careless way.</En>
          <Example>The manager brushed off her concerns without listening.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="8d6baa51-95ef-4908-af69-eee96be7a3df">
              <Vi>Phớt lờ lời đề nghị của ai đó một cách nhanh chóng.</Vi>
              <En>To quickly dismiss or ignore someone’s suggestion or request.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
