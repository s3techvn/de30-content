      <Meanings>
        <Meaning id="8f6a766c-50dd-4472-98cb-de6f5afa3a16" type="Noun">
          <Vi>Cái bàn chải</Vi>
          <En>A tool with bristles or fibers, used for cleaning, painting, or grooming.</En>
          <Example>She cleaned her teeth with a soft-bristled toothbrush.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="84c01500-f898-4030-b3af-c04ed88048ab">
              <Vi>Sử dụng bàn chải đánh răng để làm sạch răng.</Vi>
              <En>Using a toothbrush to clean teeth.</En>
            </Situation>
            <Situation id="200b0604-2cac-4406-be94-a120446b8ddf">
              <Vi>Họa sĩ dùng cọ để sơn tranh.</Vi>
              <En>A painter uses a brush to paint a picture.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="8cb609d9-029f-469b-ad02-1dae5dfe3ef7" type="Verb">
          <Vi>Chải, quét nhẹ</Vi>
          <En>To clean, paint, or smooth something using a brush; to move or act quickly and lightly.</En>
          <Example>He brushed the dust off the table with his sleeve.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="8a7ce47b-8041-4e72-a83f-98dea311f482">
              <Vi>Chải nhẹ tóc bằng lược.</Vi>
              <En>To lightly comb or smooth hair with a brush or comb.</En>
            </Situation>
            <Situation id="72119af1-516a-495c-a954-3f24f1cd9177">
              <Vi>Quét nhẹ sơn lên bề mặt.</Vi>
              <En>To apply paint to a surface with a brush.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
    </Pronunciation>
    <Pronunciation id="db940a03-604d-451b-8cdf-c96f09fb34b0" ipa="/brʌʃ/" vi_ipa="bờ-ráp">
