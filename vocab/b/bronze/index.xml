      <Meanings>
        <Meaning id="ad00df5a-3444-4313-97e3-7058fb0f41a1" type="Noun">
          <Vi>đồng thau; tượng đồng</Vi>
          <En>A hard, malleable metal alloy made primarily of copper and tin, often used for statues, coins, and musical instruments.</En>
          <Example>The museum displayed a magnificent bronze statue of a warrior.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="fc7ac20d-4864-4f8e-a25f-c554379b3f1d">
              <Vi>Ngành đúc tượng nghệ thuật và điêu khắc</Vi>
              <En>Artistic casting and sculpture industry</En>
            </Situation>
            <Situation id="9ef1ec42-77ef-45c8-9bae-a1833b563221">
              <Vi>Môn thể thao (đua thuyền): "bronze medal" – huy chương đồng</Vi>
              <En>Sports (rowing/rowing races): "bronze medal" – third-place award</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="220f947b-73ca-4cde-a88a-f1609e492cbd" type="Adjective">
          <Vi>làm bằng đồng thau; màu đồng thau</Vi>
          <En>Made of bronze; having the color of bronze (a reddish-brown hue).</En>
          <Example>The door was adorned with bronze handles.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="720259ba-94bf-4a68-af92-7d5905f08a0d">
