      <Meanings>
        <Meaning id="539103ce-90e5-4a21-a7f9-afbdc437ae61" type="Noun">
          <Vi>số</Vi>
          <En>A mathematical object used to count, measure, and label.</En>
          <Example>The number of students in the class is twenty-five.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="d1329abf-5467-463b-8111-077cfb00b98a">
              <Vi>Mô tả một lượng đếm được hoặc giá trị đo lường.</Vi>
              <En>Describing a countable quantity or measurable value.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="34497316-2e0e-40fd-9c31-fa2aedc929f3" type="Noun">
          <Vi>số (trong danh sách, thứ tự)</Vi>
          <En>A distinct item in a sequence or list, often used for identification (e.g., phone number, room number).</En>
          <Example>Her phone number is 555-1234.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="511cb57e-537c-4f95-bb6a-67a9f843197c">
              <Vi>Dùng để chỉ mã định danh như số điện thoại, số nhà, số thứ tự.</Vi>
              <En>Used to refer to identifiers such as phone numbers, house numbers, or serial numbers.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
    </Pronunciation>
