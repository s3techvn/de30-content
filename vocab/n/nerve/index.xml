      <Meanings>
        <Meaning id="c93decfa-1bcd-4bc8-b453-a80160690f4c" type="Noun">
          <Vi>thần kinh; dây thần kinh</Vi>
          <En>A bundle of fibers in the body that transmits signals between the brain and other parts of the body.</En>
          <Example>The doctor examined the patient’s facial nerve to check for damage.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="4d62ef32-5709-40c0-b38f-834b75647c0c">
              <Vi>Bác sĩ kiểm tra dây thần kinh bị tổn thương sau chấn thương.</Vi>
              <En>A doctor examines a damaged nerve after an injury.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="853cc946-06e0-48bc-910a-3845f5cf126d" type="Noun">
          <Vi>sự can đảm; sự dũng cảm (thường trong cụm “có nerve”)</Vi>
          <En>Courage or boldness, especially in a difficult or dangerous situation.</En>
          <Example>It took real nerve to speak up against the CEO in front of everyone.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="ca1cfc41-04b3-46df-b7ab-3ad0702009e7">
              <Vi>Một người dám phản đối sếp trước mặt đồng nghiệp.</Vi>
              <En>Someone dares to challenge the boss publicly during a meeting.</En>
            </Situation>
          </Situations>
        </Meaning>
