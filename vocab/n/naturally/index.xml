      <Meanings>
        <Meaning id="6abfddce-c4fd-4542-9c99-884363f49b13" type="Adverb">
          <Vi>một cách tự nhiên</Vi>
          <En>In a natural way; as expected or usual in a given situation.</En>
          <Example>She spoke naturally and confidently during the interview.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="1a091328-6358-47c3-9c05-70c426bb74dc">
              <Vi>Mô tả hành động diễn ra một cách không gượng ép, phù hợp với bản chất hoặc hoàn cảnh.</Vi>
              <En>Describing an action that occurs without artificiality, fitting the natural or expected context.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="533a83e2-2011-494e-8dc3-60b1306d7d8b" type="Adverb">
          <Vi>một cách tất yếu, tất nhiên</Vi>
          <En>As a logical or inevitable consequence; inevitably.</En>
          <Example>Naturally, he was upset when he lost the competition.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="ace25435-391d-468f-be30-1499eae0f741">
              <Vi>Dùng để diễn đạt điều xảy ra một cách tất yếu, dễ hiểu hoặc hợp lý.</Vi>
              <En>Used to express something that logically or predictably follows from a situation.</En>
            </Situation>
          </Situations>
        </Meaning>
