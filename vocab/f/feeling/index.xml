      <Meanings>
        <Meaning id="b2b8b527-855d-442e-80af-658c116b39d9" type="Noun">
          <Vi>Cảm giác; cảm xúc</Vi>
          <En>An emotional state or reaction; a physical sensation or intuition.</En>
          <Example>I had a strange feeling that I was being watched.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="e09ddec7-90b1-4df5-986a-4a2d81f86f4b">
              <Vi>Mô tả trạng thái nội tâm hoặc phản ứng cảm xúc.</Vi>
              <En>Describing an internal emotional state or reaction.</En>
            </Situation>
            <Situation id="68315543-1392-4bfc-914a-d2ae9d1a7d26">
              <Vi>Mô tả cảm giác thể chất như đau, ngứa, run rẩy.</Vi>
              <En>Describing a physical sensation such as pain, itch, or trembling.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
