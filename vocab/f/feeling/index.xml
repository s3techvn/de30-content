      <Meanings>
        <Meaning id="e17fc1eb-a857-45c4-ab1c-bb8f3c9285f3" type="Verb">
          <Vi>Cảm nhận; cảm thấy</Vi>
          <En>To be aware of a sensation or emotion through physical or mental perception.</En>
          <Example>I can feel the warmth of the sun on my skin.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="dc4318b6-cbd0-44e6-9c16-27d359e7637c">
              <Vi>Mô tả việc nhận biết một cảm giác thể chất.</Vi>
              <En>Describing awareness of a physical sensation.</En>
            </Situation>
            <Situation id="e8e3896c-9681-4b34-bab2-8496ac3b6793">
              <Vi>Mô tả việc nhận thức hoặc trải nghiệm cảm xúc.</Vi>
              <En>Describing awareness or experience of an emotion.</En>
