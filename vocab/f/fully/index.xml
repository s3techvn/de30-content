        <Meaning id="704a7151-286b-43c6-8a85-9604d4b09910" type="Adverb">
          <Vi>hoàn toàn, đầy đủ, trọn vẹn</Vi>
          <En>Completely; to the fullest extent; entirely.</En>
          <Example>She was fully prepared for the interview.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="25f2146d-6079-4377-8ff0-1fb0ac304bb7">
