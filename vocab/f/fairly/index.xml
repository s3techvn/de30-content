      <Meanings>
        <Meaning id="ef920b1d-c33c-476a-94ba-3b3000450092" type="Adverb">
          <Vi>khá, tương đối, một cách công bằng</Vi>
          <En>To a moderate degree; reasonably; or in a fair, just, or impartial manner.</En>
          <Example>She fairly aced the exam after studying for three days.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="4f235677-c9e1-4911-b97b-a07476dbe4af">
              <Vi>Mô tả mức độ trung bình–khá trong đánh giá hoặc kết quả.</Vi>
              <En>Used to describe something that is good but not excellent, or acceptable but not outstanding.</En>
            </Situation>
            <Situation id="5cfbc5a4-efc5-4244-aa02-a43fafb4c2eb">
              <Vi>Mô tả hành động được thực hiện một cách công bằng, không thiên vị.</Vi>
              <En>Used to emphasize fairness or impartiality in treatment or judgment.</En>
            </Situation>
