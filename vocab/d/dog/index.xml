      <Meanings>
        <Meaning id="c7892ea4-54b6-4036-86e5-bf6fc4e62df3" type="Noun">
          <Vi>con chó</Vi>
          <En>A domesticated carnivorous mammal that typically barks and is kept as a pet or for work.</En>
          <Example>My dog loves to chase squirrels in the park.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="db2e89f1-a08b-4489-9b19-429b6437b871">
              <Vi>Người nuôi chó đi dạo cùng thú cưng mỗi sáng.</Vi>
              <En>A person walks their pet dog every morning.</En>
            </Situation>
            <Situation id="831f997e-158e-4611-8c7f-e559bae30e1a">
              <Vi>Một chú chó nghiệp vụ giúp cảnh sát tìm người mất tích.</Vi>
              <En>A police dog helps officers locate missing persons.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="e3ca32d8-f382-4f34-8be3-baf24d9061d5" type="Noun">
          <Vi>người khinh thường, kẻ đáng ghét (từ lóng)</Vi>
          <En>A contemptible or unpleasant person (slang, often used informally or pejoratively).</En>
          <Example>He’s such a dog when he’s stressed—he snaps at everyone.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="4ec0ea98-ffd6-49f3-8a33-3bf0fcb1b68d">
              <Vi>Người bạn chê bai bạn mình vì hành vi thô lỗ.</Vi>
              <En>A friend calls another friend a “dog” after they behave rudely.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
