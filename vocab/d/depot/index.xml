      <Meanings>
        <Meaning id="1c8ebe92-d764-4473-b796-2ed357e0f7b5" type="Noun">
          <Vi>Kho chứa, bến xe, trạm lưu giữ (xe, thiết bị, hàng hóa)</Vi>
          <En>A building or place used for storing vehicles, equipment, or goods, especially buses, trains, or military supplies.</En>
          <Example>The bus depot is located just outside the city center.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
