      <Meanings>
        <Meaning id="7b512510-5a6d-4bb1-abd6-f741f0822a8d" type="Noun">
          <Vi>Chẩn đoán; chẩn bệnh</Vi>
          <En>The identification of the nature of an illness or other problem by examination of the symptoms.</En>
          <Example>The doctor made a final diagnosis after reviewing all the test results.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="a3c7438a-34a9-44e2-9c14-02ae9d1eacf3">
              <Vi>Bác sĩ đưa ra chẩn đoán cuối cùng sau khi xem xét kết quả xét nghiệm.</Vi>
              <En>The doctor gives the final diagnosis after reviewing test results.</En>
            </Situation>
            <Situation id="99214e4e-49ed-44bc-8eb0-3c6b36b98c24">
              <Vi>Chẩn đoán sớm giúp điều trị hiệu quả hơn.</Vi>
              <En>Early diagnosis helps enable more effective treatment.</En>
            </Situation>
          </Situations>
