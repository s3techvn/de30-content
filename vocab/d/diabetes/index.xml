      <Meanings>
        <Meaning id="75dfa2ca-3c4f-4e58-b772-90605350cc9e" type="Noun">
          <Vi>Bệnh tiểu đường</Vi>
          <En>A chronic medical condition in which the body cannot properly regulate blood sugar levels due to insufficient insulin production or insulin resistance.</En>
          <Example>People with diabetes need to monitor their blood glucose levels regularly.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="c8143285-abda-405f-a777-4a21da00f339">
              <Vi>Chẩn đoán và điều trị bệnh tiểu đường tại phòng khám.</Vi>
              <En>Diagnosis and treatment of diabetes in a clinic.</En>
            </Situation>
            <Situation id="43e378ef-5548-44b1-b299-22b1e0e2cea3">
              <Vi>Người bệnh tiểu đường phải tuân thủ chế độ ăn uống và tập luyện nghiêm ngặt.</Vi>
              <En>People with diabetes must follow strict diet and exercise regimens.</En>
            </Situation>
          </Situations>
        </Meaning>
