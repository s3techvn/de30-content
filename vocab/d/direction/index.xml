              <En>Giving instructions on how to reach a location while walking or driving.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="7b3d9433-9fd7-4bbb-b5d1-61bfbfb52c11" type="Noun">
          <Vi>sự chỉ đạo, chỉ thị</Vi>
          <En>Instructions or orders given by a leader or authority figure.</En>
          <Example>He acted without direction from his manager and made a mistake.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="f8c1697b-5a20-41dc-a9dc-d7f7e55896e5">
