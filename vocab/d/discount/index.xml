      <Meanings>
        <Meaning id="c7a25e2e-92ba-4e92-859a-2f6a68494bb8" type="Verb">
          <Vi>Giảm giá; loại trừ; xem nhẹ</Vi>
          <En>To reduce the price of something; to disregard or dismiss something as unimportant.</En>
          <Example>The shopkeeper discounted the damaged item by 30%.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="e384e90c-8b6e-47a9-b5d4-845eee7f7838">
              <Vi>Nhân viên bán hàng giảm giá cho khách thân thiết.</Vi>
              <En>A sales clerk gives a price reduction to a loyal customer.</En>
            </Situation>
            <Situation id="abc26ac0-9475-428a-8b3a-ecb8aef440a0">
              <Vi>Anh ấy luôn loại trừ những ý kiến trái chiều mà không cân nhắc kỹ.</Vi>
              <En>He always dismisses opposing opinions without careful consideration.</En>
