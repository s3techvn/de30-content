      <Meanings>
        <Meaning id="73f2eb24-1e14-4e9b-8791-a8982bf30a96" type="Noun">
          <Vi>Giảm giá; chiết khấu</Vi>
          <En>A reduction in the usual price of something.</En>
          <Example>The store offered a 20% discount on all summer clothing.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="f1fa4cf2-e451-410c-8fb8-f634b870765b">
              <Vi>Khách hàng được giảm giá khi mua hàng vào dịp khuyến mãi.</Vi>
              <En>A customer receives a price reduction during a promotional sale.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
