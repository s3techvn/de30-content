      <Meanings>
        <Meaning id="787cc4e5-8884-4b49-ab62-eaf548515b81" type="Noun">
          <Vi>Phản ứng</Vi>
          <En>A response or reaction to a stimulus, event, or situation.</En>
          <Example>She had a violent reaction to the medication.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="26b7d878-7ca2-44c1-98a7-8a9a94219364">
              <Vi>Một phản ứng mạnh về mặt cảm xúc hoặc thể chất trước một kích thích.</Vi>
              <En>A strong emotional or physical response to a stimulus.</En>
            </Situation>
            <Situation id="dc8856af-655e-46b6-8e48-07bb2bac5420">
              <Vi>Phản ứng hóa học giữa các chất.</Vi>
              <En>A chemical reaction between substances.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="d1926413-2b44-4745-a97d-8ce670493600" type="Noun">
          <Vi>Phản ứng (trong hóa học)</Vi>
          <En>A process in which one or more substances are converted into different substances.</En>
          <Example>The reaction between hydrogen and oxygen produces water.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="945116a8-087a-4e98-82fa-5216a524761f">
              <Vi>Mô tả quá trình hóa học xảy ra trong phòng thí nghiệm.</Vi>
              <En>Describing a chemical process occurring in a laboratory.</En>
            </Situation>
          </Situations>
        </Meaning>
