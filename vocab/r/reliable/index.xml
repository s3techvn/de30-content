      <Meanings>
        <Meaning id="d1246258-b692-4b67-ad82-3917c8c83295" type="Adjective">
          <Vi>Đáng tin cậy; đáng tin tưởng</Vi>
          <En>Consistently good in quality or performance; able to be trusted or believed.</En>
          <Example>She is a reliable source of information; you can always count on her to be on time.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
