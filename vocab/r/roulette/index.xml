      <Meanings>
        <Meaning id="d844da92-cac1-45bc-96ad-ecea2360cb9b" type="Noun">
          <Vi>Trò quay số (trong sòng bạc), bánh xe roulette</Vi>
          <En>A gambling game in which a small ball is spun around a wheel with numbered and colored compartments, and players bet on where the ball will land.</En>
          <Example>He placed a bet on red at the roulette table.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="7b79e681-af86-4e76-b9b5-d013e876e91f">
              <Vi>Một người chơi đặt cược vào các ô màu đỏ hoặc đen trên bánh xe quay.</Vi>
              <En>A player places bets on red or black numbers before the wheel is spun.</En>
            </Situation>
            <Situation id="62447cd4-8538-4459-a71d-5564b73a39f6">
              <Vi>Các sòng bạc thường đặt roulette ở vị trí trung tâm để thu hút khách.</Vi>
              <En>Roulette tables are often placed in prominent locations in casinos to attract players.</En>
            </Situation>
          </Situations>
        </Meaning>
