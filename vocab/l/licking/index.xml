      <Meanings>
        <Meaning id="98371620-2857-4c13-8136-613de4554af5" type="Verb">
          <Vi>liếm, liếm nhanh</Vi>
          <En>to pass the tongue over (a surface or substance), typically quickly or repeatedly</En>
          <Example>She gave the ice cream cone a quick licking before it melted.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="f85f8a5e-f73b-4f3a-b1c7-31f8b47e464f">
              <Vi>Mô tả hành động động vật (như chó, mèo) hoặc người liếm đồ vật, thức ăn, hoặc da.</Vi>
              <En>Describes the action of an animal (e.g., dog, cat) or person licking an object, food, or skin.</En>
            </Situation>
            <Situation id="37e0fa13-ca2e-4584-9beb-b835bacd7374">
              <Vi>Trong nấu ăn: liếm muỗng hoặc nếm thử món ăn đang chế biến.</Vi>
              <En>In cooking: tasting a dish by licking a spoon while preparing it.</En>
            </Situation>
          </Situations>
        </Meaning>
