  <Pronunciations>
    <Pronunciation id="95099856-18a4-474d-8829-a22e6f80760c" ipa="/ˈlɪt.əl/" vi_ipa="lít-ơ">
      <Audios>
        <Audio type="male_normal" value="./male_normal.mp3" />
