      <Meanings>
        <Meaning id="1c13976b-1ca2-4a31-8431-5442c1370cc7" type="Adjective">
          <Vi>nhỏ, ít, không đáng kể</Vi>
          <En>small in size, amount, or degree; not much.</En>
          <Example>She lives in a little house near the park.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="79681395-d218-4b82-9766-eb90c38f3dd8">
              <Vi>Mô tả vật có kích thước nhỏ hơn mức trung bình.</Vi>
              <En>Describing an object that is smaller than average.</En>
            </Situation>
            <Situation id="e31df292-6979-444c-9a24-519f9b96a236">
              <Vi>Dùng để nhấn mạnh sự khiêm tốn hoặc khiếm khuyết nhẹ.</Vi>
              <En>Used to emphasize modesty or minor shortcomings.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="8848c415-5bfe-46e9-a25f-eafc3998da08" type="Adjective">
          <Vi>ít, không nhiều (dùng với danh từ không đếm được)</Vi>
          <En>not much (used with uncountable nouns).</En>
          <Example>We have little time left before the meeting starts.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="76c38500-a59f-471c-9aa5-fb5b9caa3e1f">
              <Vi>Trong ngữ cảnh nhấn mạnh sự thiếu hụt nghiêm trọng.</Vi>
              <En>In contexts emphasizing a serious lack of something uncountable.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="df785bf9-8a2b-4788-b81c-b7ec0769d2f0" type="Adverb">
          <Vi>một chút, không nhiều</Vi>
          <En>to a small extent or degree; slightly.</En>
          <Example>Could you please speak a little slower?</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="3362097d-e33d-4fd1-92f9-c65f106ab63c">
              <Vi>Trong yêu cầu lịch sự để điều chỉnh hành vi.</Vi>
              <En>In polite requests to adjust someone’s behavior.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
    </Pronunciation>
