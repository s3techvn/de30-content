      <Meanings>
        <Meaning id="356e2486-6b8a-41c7-a734-140ee97bf7b7" type="Verb">
          <Vi>đảm bảo, làm cho chắc chắn</Vi>
          <En>To make certain that something will happen or is true; to remove doubt.</En>
          <Example>I assure you that the project will be completed on time.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="0d233089-137c-4bd3-b7b3-e745b7f0a4b8">
              <Vi>Nhấn mạnh với ai đó rằng điều gì đó là chắc chắn, nhằm xoa dịu lo lắng.</Vi>
              <En>Reassuring someone by emphasizing certainty about a future event or fact.</En>
            </Situation>
            <Situation id="ece5abe1-4980-4d52-9ae0-7b4a8a50d6cf">
              <Vi>Đưa ra lời hứa hoặc cam kết rõ ràng để tạo niềm tin.</Vi>
              <En>Providing a clear promise or guarantee to build trust.</En>
            </Situation>
