        <Meaning id="6f2994e9-45ed-4899-9059-3228afc0c58e" type="Adjective">
          <Vi>thực sự, chính gốc, không giả tạo</Vi>
          <En>Not false or copied; genuine, real, or original.</En>
          <Example>The restaurant serves authentic Thai cuisine made with traditional recipes.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="e678c9c2-81c7-419e-b0d1-161b40fba4f8">
