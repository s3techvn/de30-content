      <Meanings>
        <Meaning id="2a689faf-1bdf-4902-80b5-5df1b49aa147" type="Noun">
          <Vi>Hành động</Vi>
          <En>A thing done; an act or deed.</En>
          <Example>She took quick action to resolve the issue.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="115448fb-eb06-4dd7-a6e2-75b411259a9a">
              <Vi>Mô tả một việc cụ thể được thực hiện bởi một người hoặc tổ chức.</Vi>
              <En>Describes a specific deed or activity carried out by a person or group.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="9a0e0036-5b28-491d-8a1b-08d88c6bf1d4" type="Noun">
          <Vi>Hành động (trong phim, kịch)</Vi>
          <En>The part of a film, play, or story involving events and activities, especially physical or dramatic sequences.</En>
          <Example>The action in the movie intensifies during the final act.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="58925cb4-9cd4-48b3-ae64-d8e70b4928ea">
              <Vi>Mô tả các cảnh quay hoặc phân đoạn kịch tính trong phim hoặc vở kịch.</Vi>
              <En>Refers to dramatic or physically intense scenes in film or theater.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="62efc665-da32-48cc-be49-415ef5874f93" type="Noun">
          <Vi>Luật: Khiếu nại hoặc vụ kiện</Vi>
          <En>A legal proceeding or lawsuit.</En>
          <Example>He filed an action against the company for breach of contract.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="321cece2-8d32-48b8-bc01-970ff5539d44">
              <Vi>Mô tả việc khởi kiện hoặc vụ việc pháp lý đang được xử lý.</Vi>
              <En>Refers to a formal legal case or lawsuit initiated in court.</En>
            </Situation>
          </Situations>
        </Meaning>
