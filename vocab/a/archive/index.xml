      <Meanings>
        <Meaning id="54cd69bb-c2f2-4f33-9b8d-1fe25940081a" type="Noun">
          <Vi>Cơ sở lưu trữ; kho lưu trữ; hồ sơ lưu trữ</Vi>
          <En>A collection of historical records or documents, especially one stored in a fixed location and made available for public or scholarly use.</En>
          <Example>The university’s archive contains letters written by Nobel laureates.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="d6d20d00-9853-45ac-a83f-65af113a22e4">
              <Vi>Thư viện hoặc tổ chức lưu giữ tài liệu lịch sử, văn bản quý hiếm.</Vi>
              <En>A library or institution preserving historical documents and rare texts.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
