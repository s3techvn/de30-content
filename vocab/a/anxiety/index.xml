      <Meanings>
        <Meaning id="79a84293-5d1d-4b24-b2be-7b4df623a1de" type="Noun">
          <Vi>Sự lo âu, sự bồn chồn, sự hoảng loạn nhẹ</Vi>
          <En>A feeling of worry, nervousness, or unease about something with an uncertain outcome.</En>
          <Example>She felt a wave of anxiety before her job interview.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="4bf0d98a-d671-4110-a0ee-92909bd833a7">
              <Vi>Cảm giác lo lắng trước khi thi hoặc phỏng vấn</Vi>
              <En>Feeling nervous before an exam or job interview.</En>
            </Situation>
            <Situation id="2bda4a14-c9cc-4d80-b192-d74e2c74cb4a">
              <Vi>Hội chứng lo âu lan tỏa (generalized anxiety disorder)</Vi>
              <En>Generalized anxiety disorder (GAD), where worry is persistent and excessive.</En>
            </Situation>
