      <Meanings>
        <Meaning id="124e0ca7-c7f2-48a1-baae-11a45097e87f" type="Noun">
          <Vi>Quyền truy cập; sự tiếp cận; cổng vào</Vi>
          <En>The ability or right to see, use, or enter something; a way of entering or reaching something.</En>
          <Example>She requested administrative access to the server.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="5ee4f5a3-eaf2-444b-9cea-43f3995c0542">
              <Vi>Một người dùng cần quyền để mở tệp tin hoặc hệ thống.</Vi>
              <En>A user needs permission to open a file or system.</En>
            </Situation>
            <Situation id="ba77c4f7-ea1a-4865-af43-adad55e28f46">
              <Vi>Công trình xây dựng có lối vào dành cho người khuyết tật.</Vi>
              <En>The building has wheelchair access.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
