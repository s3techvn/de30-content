      <Meanings>
        <Meaning id="d133f934-96e5-4667-868d-a2c132348007" type="Noun">
          <Vi>tro tàn; tro bụi</Vi>
          <En>The powdery residue left after something is burned.</En>
          <Example>The campfire had died down, leaving only a bed of ash.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="1448782f-f56d-460e-8844-a2bd09e59282">
              <Vi>Mô tả chất bột xám còn lại sau khi gỗ hoặc giấy bị đốt cháy.</Vi>
              <En>Describes the gray, powdery residue remaining after wood or paper is burned.</En>
            </Situation>
            <Situation id="aa519d84-a6b2-4004-83e2-d9710e304782">
              <Vi>Trong các vụ cháy lớn, tro có thể được phát tán vào không khí.</Vi>
              <En>In large fires, ash can be dispersed into the air.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="24d46cac-2cdf-4ef1-980f-bc491f33c419" type="Noun">
          <Vi>tro (trong tên người): Ash (họ tên)</Vi>
          <En>A proper noun, commonly used as a surname or given name.</En>
          <Example>Ash Ketchum is the protagonist of the Pokémon anime series.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="465e66ee-ecb2-4e82-9d63-dc165da36721">
              <Vi>Dùng để chỉ một nhân vật trong truyện, phim, hoặc tên người thật.</Vi>
              <En>Used to refer to a character in fiction or a real person’s name.</En>
            </Situation>
          </Situations>
        </Meaning>
