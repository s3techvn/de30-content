      <Meanings>
        <Meaning id="57b411a7-4b26-4f87-9b68-ea2f109ea4b2" type="Noun">
          <Vi>Áp lực</Vi>
          <En>The force applied per unit area on a surface, or the psychological stress experienced by a person.</En>
          <Example>High blood pressure can lead to serious health problems.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="fd44f72c-8bae-41af-9543-b822689a9531">
              <Vi>Một bác sĩ đo huyết áp cho bệnh nhân.</Vi>
              <En>A doctor measuring a patient's blood pressure.</En>
            </Situation>
            <Situation id="2b64cb8e-869d-47ab-8ef4-176085e6eed7">
              <Vi>Cảm giác bị áp lực từ công việc hoặc học tập.</Vi>
              <En>Feeling stressed due to work or academic demands.</En>
            </Situation>
          </Situations>
        </Meaning>
