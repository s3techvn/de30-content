      <Meanings>
        <Meaning id="38a10a65-730e-4b3f-8ca2-702bbff4702a" type="Verb">
          <Vi>xin (điều gì đó một cách lịch sự)</Vi>
          <En>To ask for something in a polite or courteous way.</En>
          <Example>Please pass the salt.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="4b6e1095-6159-442e-bbcf-00119e71c945">
              <Vi>Yêu cầu người khác làm điều gì đó một cách lịch sự trong giao tiếp hàng ngày.</Vi>
              <En>Making a polite request in everyday conversation, such as asking for an item or favor.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="c5280750-39d6-480b-a443-6003e61deb79" type="Interjection">
          <Vi>xin vui lòng (dùng để làm cho lời yêu cầu hoặc lời mời trở nên lịch sự hơn)</Vi>
          <En>Used to make a request or invitation more polite; often placed at the beginning or end of a sentence.</En>
          <Example>Could you help me, please?</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="e58fe40c-0258-41b3-8fe4-ada626d50076">
              <Vi>Đặt ở cuối câu để thể hiện sự lịch sự khi đưa ra yêu cầu hoặc lời mời.</Vi>
              <En>Placed at the end of a sentence to soften a request or invitation, especially in service or formal contexts.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
