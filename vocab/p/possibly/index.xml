      <Meanings>
        <Meaning id="d2afa8e4-146d-4206-8990-ebc67c41eaab" type="Adverb">
          <Vi>Có thể, có lẽ, có khả năng</Vi>
          <En>Used to indicate that something is possible or might be the case, but not certain.</En>
          <Example>We might go to the park later—possibly if the weather improves.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="57f7f635-c6b1-4467-963f-827b10c3a8fa">
              <Vi>Thể hiện sự không chắc chắn khi đưa ra dự đoán hoặc khả năng xảy ra.</Vi>
              <En>Used when expressing uncertainty about a future event or possibility.</En>
            </Situation>
            <Situation id="73501d91-dbd4-4364-b63f-110ae2f0cf78">
              <Vi>Được dùng trong văn nói và văn viết để làm mềm phát biểu, tránh khẳng định tuyệt đối.</Vi>
              <En>Used in speech and writing to soften a statement and avoid absolute certainty.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
