      <Meanings>
        <Meaning id="4e8f8e92-34fc-4757-baaf-595f714d5c29" type="Noun">
          <Vi>Máy bay</Vi>
          <En>A powered flying vehicle with fixed wings and a tailplane.</En>
          <Example>The plane took off smoothly despite the strong crosswind.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="925ab9ad-4093-45d4-af8b-e9877b63d200">
              <Vi>Tình huống khi một hành khách lên máy bay để đi du lịch.</Vi>
              <En>A passenger boarding an airplane for a trip.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="d5287a97-d57b-4423-b1fc-ef026a2ec5d7" type="Noun">
          <Vi>Mặt phẳng (trong hình học)</Vi>
          <En>A flat or level surface, especially one that is perfectly smooth and even.</En>
          <Example>The carpenter used a level to ensure the shelf was perfectly plane.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="69a4b945-c186-4766-b01c-1e706ed8676d">
              <Vi>Tình huống khi một thợ mộc kiểm tra độ phẳng của bề mặt gỗ.</Vi>
              <En>A carpenter checking the flatness of a wooden surface.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="8fecdfba-78c7-4c58-83a2-c663b035ffa7" type="Verb">
          <Vi>Làm phẳng (bề mặt)</Vi>
          <En>To make a surface smooth and level, especially with a tool such as a plane.</En>
          <Example>He planed the rough wood until it was smooth to the touch.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="21e20331-57df-4195-add5-ff0eff39e081">
              <Vi>Tình huống khi thợ mộc dùng dụng cụ làm phẳng gỗ trước khi sơn.</Vi>
              <En>A carpenter smoothing wood with a hand plane before painting.</En>
            </Situation>
          </Situations>
        </Meaning>
