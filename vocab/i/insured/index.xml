      <Meanings>
        <Meaning id="b9b4e348-e4dc-43b9-9ed1-36dc2ca9d933" type="Adjective">
          <Vi>Được bảo hiểm, có bảo hiểm</Vi>
          <En>Covered by insurance.</En>
          <Example>The insured property was completely destroyed in the fire, but the costs were covered.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="addaffff-38fe-4226-8a39-3c5307f22f4d">
              <Vi>Khi thảo luận về tài sản hoặc cá nhân có hợp đồng bảo hiểm bảo vệ.</Vi>
              <En>When discussing property or individuals protected by an insurance policy.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="90d3d505-2ab4-4e49-abd6-516fc3f8f5d1" type="Noun">
          <Vi>Người được bảo hiểm, bên được bảo hiểm</Vi>
          <En>A person or organization covered by insurance.</En>
          <Example>The insurance company paid the full claim to the insured after the accident.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="6aa6869b-9b9f-4839-acae-6be6d0a29706">
              <Vi>Trong các văn bản pháp lý, hợp đồng bảo hiểm hoặc khi giải quyết bồi thường.</Vi>
              <En>In legal documents, insurance policies, or during claim settlements.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
