      <Meanings>
        <Meaning id="95b0a81b-70f6-40bd-9243-e696a46f7180" type="Verb">
          <Vi>tăng, gia tăng</Vi>
          <En>to become greater in size, amount, or degree</En>
          <Example>The company plans to increase its workforce by 20% next year.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="ea5d3c42-fbd6-4fce-a825-eb4fa986757a">
              <Vi>Thể hiện sự tăng lên về số lượng, quy mô, hoặc mức độ.</Vi>
              <En>Used when describing growth in quantity, scale, or intensity.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="2b100f83-de90-4467-a4e4-99167130cabc" type="Noun">
          <Vi>sự tăng, mức tăng</Vi>
          <En>a positive change in size, amount, or degree</En>
          <Example>She received a salary increase after six months of excellent performance.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="089d384f-c8b8-48ae-aa45-7a509fc97963">
              <Vi>Dùng để chỉ mức tăng cụ thể, đặc biệt trong tiền lương hoặc doanh thu.</Vi>
              <En>Used to refer to a specific rise, especially in wages, prices, or revenue.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
