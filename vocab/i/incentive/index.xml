      <Meanings>
        <Meaning id="7f208004-f92a-4b2d-9e00-14ed27b66be5" type="Noun">
          <Vi>Động lực; phần thưởng khuyến khích</Vi>
          <En>A reason for doing something, typically one that motivates or encourages someone to act.</En>
          <Example>The company offered a bonus as an incentive for employees to meet their sales targets.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="348a5c61-f844-4c2d-94d9-fc6f3a81d7d2">
