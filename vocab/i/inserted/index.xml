      <Meanings>
        <Meaning id="ba14f277-6708-42b8-a2fe-9a416828c7be" type="Adjective">
          <Vi>được chèn vào</Vi>
          <En>Put or inserted (as a component, text, or object) into something else.</En>
          <Example>The new paragraph was inserted between the second and third sections.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="77ce6576-e4cd-4e25-b684-d070b8578f69">
              <Vi>Mô tả một phần văn bản, hình ảnh, hoặc đối tượng đã được thêm vào một tài liệu hoặc hệ thống.</Vi>
              <En>Describes a text segment, image, or object that has been added into a document or system.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="6155f684-09a6-400d-bf3d-c886a9251040" type="Verb (past tense/participle)">
          <Vi>đã chèn</Vi>
          <En>Past tense and past participle of *insert*, meaning to put something inside or into something else.</En>
          <Example>She inserted the key into the lock and turned it.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="6cd7e739-4b8c-44f9-8728-908739d6553e">
              <Vi>Mô tả hành động đã thực hiện chèn một vật vào một vị trí cụ thể.</Vi>
              <En>Describes the action of placing an object into a specific location.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
