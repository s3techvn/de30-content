      <Meanings>
        <Meaning id="199b1aef-da55-4e98-8ef2-e8a42d34a341" type="Noun">
          <Vi>Tác động; va chạm; sức ảnh hưởng mạnh mẽ</Vi>
          <En>A strong effect or influence, especially one that causes a significant change</En>
          <Example>The new policy had a major impact on the company’s profits.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="f736cd03-84e9-48b7-b21c-92667b189a1d">
              <Vi>Mô tả hậu quả mạnh mẽ của một sự kiện hoặc quyết định.</Vi>
              <En>Describing the strong consequence of an event or decision.</En>
            </Situation>
            <Situation id="84abcc3a-a2f4-4490-a9bb-9a93a57b7167">
              <Vi>Chỉ sự va chạm vật lý giữa hai vật.</Vi>
              <En>Referring to a physical collision between two objects.</En>
            </Situation>
          </Situations>
        </Meaning>
