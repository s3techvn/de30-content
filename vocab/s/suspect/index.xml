      <Meanings>
        <Meaning id="a3a7b142-8c94-4c7f-8622-4231636e0956" type="Verb">
          <Vi>ngờ, nghi ngờ</Vi>
          <En>to have an idea or suspicion that something is the case, especially something bad or wrong</En>
          <Example>I suspect he’s lying about where he was last night.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="439044a2-e420-4509-80da-bb13d291a231">
              <Vi>Thể hiện sự hoài nghi về một điều gì đó, thường là hành vi hoặc lời nói không đáng tin cậy.</Vi>
              <En>Expressing doubt or mistrust about someone’s actions or statements.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
