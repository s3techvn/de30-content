      <Meanings>
        <Meaning id="d169bd68-79a1-443a-a50e-a5da6a998dc8" type="Noun">
          <Vi>người bị nghi, nghi phạm</Vi>
          <En>a person who is suspected of committing a crime or doing something wrong</En>
          <Example>The police are still searching for the main suspect in the robbery.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="bb85eccd-63b0-48f6-aef8-28423b442289">
              <Vi>Sử dụng trong điều tra hình sự để chỉ người có dấu hiệu phạm tội.</Vi>
              <En>Used in criminal investigations to refer to someone believed to be involved in a crime.</En>
            </Situation>
          </Situations>
