      <Meanings>
        <Meaning id="c77e5b03-f2d0-4acf-aa9f-842e3425e406" type="Adjective">
          <Vi>độc diễn; một mình, đơn độc</Vi>
          <En>performed or done by one person alone; solitary</En>
          <Example>She gave a stunning solo performance at the concert.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="092fb6b8-a4e5-41b3-9d99-08133ccd9f64">
              <Vi>Một nghệ sĩ biểu diễn một mình trên sân khấu.</Vi>
              <En>An artist performs alone on stage.</En>
            </Situation>
            <Situation id="df2df2ca-5c4d-4931-9567-4151a1ce9e0f">
              <Vi>Một chuyến đi không có bạn đồng hành.</Vi>
              <En>A trip taken without any companions.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="db474528-aec2-410d-83d9-9a972d7c449e" type="Noun">
          <Vi>bản độc diễn; người biểu diễn độc diễn</Vi>
          <En>a musical piece performed by a single performer, or the performer themselves</En>
          <Example>The violinist’s solo was met with thunderous applause.</Example>
