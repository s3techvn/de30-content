      <Meanings>
        <Meaning id="97c39171-dd28-4e03-a8ff-dbcf0f1dfede" type="Adverb">
          <Vi>Đáng kể; về cơ bản; một cách đáng kể</Vi>
          <En>In a way that is large enough to have a significant effect or to be important; to a considerable extent</En>
          <Example>The new policy has substantially improved employee satisfaction.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="925110b7-9226-470b-85c7-7e7726e3be2e">
              <Vi>Mô tả mức độ thay đổi hoặc ảnh hưởng lớn trong báo cáo hoặc phân tích.</Vi>
              <En>Used in reports or analyses to indicate a meaningful or notable change or effect.</En>
            </Situation>
            <Situation id="47fea76a-5d51-4ad7-9e29-5e937ecc8c4c">
              <Vi>Dùng để làm rõ rằng một sự khác biệt là đáng kể, không chỉ nhỏ nhặt.</Vi>
              <En>Used to emphasize that a difference is meaningful, not merely superficial or minor.</En>
            </Situation>
          </Situations>
        </Meaning>
