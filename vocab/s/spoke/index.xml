      <Meanings>
        <Meaning id="db000992-b489-43fb-b2cf-6622c75c508e" type="Verb">
          <Vi>đi xe đạp (quá khứ của speak, nhưng trong ngữ cảnh này là lỗi chính tả – đúng là spoke là quá khứ của speak, nhưng nếu ngữ cảnh là xe đạp thì là spoke = nan hoa, nhưng "spoke" không có dạng động từ nguyên thể; cần kiểm tra lại ngữ cảnh)</Vi>
          <En>to have said something in the past (past tense of *speak*); also, a rigid rod connecting the hub to the rim of a wheel</En>
          <Example>She spoke clearly during the presentation.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="4e9a368b-5907-4e1b-b866-53daaf9a6928">
              <Vi>Một người đang phát biểu trong hội nghị.</Vi>
              <En>A person giving a speech in a conference.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
