      <Meanings>
        <Meaning id="9aad83bf-3811-491c-b797-3b0745408e29" type="Noun">
          <Vi>Tốc độ</Vi>
          <En>The rate at which someone or something moves or operates.</En>
          <Example>She increased the speed of the car as she entered the highway.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="a4b68069-89ff-416b-857c-227f14dafb68">
              <Vi>Mô tả mức độ nhanh hoặc chậm của chuyển động.</Vi>
              <En>Describing how fast or slow something moves.</En>
            </Situation>
            <Situation id="83533a69-fb25-4d2c-bbd5-3e8b60ebde12">
              <Vi>Tốc độ xử lý trong công nghệ (ví dụ: tốc độ internet).</Vi>
              <En>Processing rate in technology (e.g., internet speed).</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="665fe653-524e-4f23-ac56-dc3e7bbe13b0" type="Verb">
          <Vi>Tăng tốc, làm nhanh lên</Vi>
          <En>To move or cause to move faster than usual.</En>
          <Example>The cheetah sped away as soon as it spotted its prey.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="6ac357c1-1008-4557-b298-c6aeebcd5e6f">
              <Vi>Hành động tăng vận tốc khi di chuyển.</Vi>
              <En>The action of increasing movement velocity.</En>
            </Situation>
            <Situation id="ed1bf91a-1190-4a96-9734-6b36c3a928f3">
              <Vi>Làm cho một quá trình diễn ra nhanh hơn (ẩn dụ).</Vi>
              <En>To make a process happen more quickly (figuratively).</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
