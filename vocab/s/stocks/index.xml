      <Meanings>
        <Meaning id="af8f9a9e-bd6c-47eb-bd8a-76ecf44aa986" type="Noun">
          <Vi>Cổ phiếu</Vi>
          <En>Shares of ownership in a company, typically traded on a stock exchange.</En>
          <Example>She bought 100 shares of Apple stocks last week.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="2988467e-f8c2-42f0-8d56-548cbb8b9bfe">
              <Vi>Mua bán cổ phiếu trên sàn chứng khoán.</Vi>
              <En>Buying and selling shares on the stock market.</En>
            </Situation>
            <Situation id="df4005ac-24db-43e4-8eb0-6d86a75f5ef8">
              <Vi>Theo dõi biến động giá cổ phiếu hàng ngày.</Vi>
              <En>Monitoring daily fluctuations in stock prices.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="dbabf7ba-7703-4dc5-ac91-435f6c0a05b5" type="Noun">
          <Vi>Hàng tồn kho; dự trữ</Vi>
          <En>Goods or materials held by a business for sale or production.</En>
          <Example>The supermarket ran out of stocks of fresh produce after the holiday rush.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="34bc9a4d-301a-4667-b096-a44ae6f03cb7">
              <Vi>Kiểm kê hàng tồn kho cuối tháng.</Vi>
              <En>Conducting a month-end inventory check.</En>
            </Situation>
            <Situation id="7d3c5f56-c06e-406b-97bc-48fcb61ec852">
              <Vi>Nhập thêm hàng vào kho khi dự trữ thấp.</Vi>
              <En>Restocking shelves when inventory levels are low.</En>
            </Situation>
          </Situations>
        </Meaning>
