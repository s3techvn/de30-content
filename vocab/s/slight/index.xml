      <Meanings>
        <Meaning id="d7c956b1-01e4-4ae0-b81a-aa965b5f7b50" type="Adjective">
          <Vi>nhỏ, nhẹ, không đáng kể</Vi>
          <En>small in degree or amount; not significant.</En>
          <Example>The difference in their heights is only slight.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="9aee10ee-14a2-4f42-993d-171a0e937334">
              <Vi>Mô tả sự khác biệt nhỏ, không rõ rệt.</Vi>
              <En>Describing a small, barely noticeable difference.</En>
            </Situation>
            <Situation id="889dba0f-6344-4470-82a1-2bcfe9c2d34b">
              <Vi>Dùng khi muốn làm nhẹ mức độ của một nhận xét.</Vi>
              <En>Used to soften the intensity of a statement.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="cde2c46f-e37a-4e34-b50c-9a1c4cb8ff77" type="Verb">
          <Vi>xem thường, khinh thường</Vi>
          <En>to treat or consider as unimportant or unworthy of attention.</En>
          <Example>She felt slighted when he didn’t invite her to the meeting.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="d734ed24-ee06-41ef-a735-98928f6c7a6f">
              <Vi>Cảm giác bị coi thường trong giao tiếp hoặc xã giao.</Vi>
              <En>Feeling dismissed or ignored in a social or professional interaction.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
