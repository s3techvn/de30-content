      <Meanings>
        <Meaning id="e820f6d9-383c-4117-bf80-ee3e85576064" type="Verb">
          <Vi>Ký kết để nhận (dịch vụ, tạp chí, nội dung…)</Vi>
          <En>To agree to receive or pay for a product, service, or content regularly, typically in exchange for a fee.</En>
          <Example>She subscribed to the monthly magazine and receives it every first Monday.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="d5e9e629-e6aa-4d16-b45b-48ade773de29">
              <Vi>Đăng ký nhận bản tin, nội dung trực tuyến, hoặc dịch vụ trả phí.</Vi>
              <En>Signing up to receive newsletters, online content, or paid services.</En>
            </Situation>
            <Situation id="7c92a16b-1615-4fff-9b26-d85a6123ad19">
              <Vi>Đặt mua định kỳ một ấn phẩm (như báo, tạp chí).</Vi>
              <En>Ordering a publication (e.g., newspaper, magazine) on a recurring basis.</En>
            </Situation>
          </Situations>
        </Meaning>
