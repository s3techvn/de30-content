      <Meanings>
        <Meaning id="629d8ab4-c68c-425b-9b3f-db49469cdf21" type="Noun">
          <Vi>Chuyên môn; sở trường; món đặc sản (đặc biệt nổi bật)</Vi>
          <En>A particular skill, activity, or subject in which someone has great knowledge or ability; a dish that a restaurant is especially known for.</En>
          <Example>Her specialty is French cuisine, especially soufflés.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="1e06b49a-63ec-4354-9a1d-d6bc931997c6">
              <Vi>Một bác sĩ được đào tạo chuyên sâu về một lĩnh vực y tế cụ thể.</Vi>
              <En>A doctor who has advanced training and expertise in a specific area of medicine.</En>
            </Situation>
            <Situation id="367b6924-cb9f-4e1b-957d-802bd26f4c6f">
              <Vi>Món ăn nổi bật nhất trong thực đơn của nhà hàng.</Vi>
              <En>The most famous or signature dish served by a restaurant or chef.</En>
            </Situation>
          </Situations>
