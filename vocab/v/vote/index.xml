      <Meanings>
        <Meaning id="fe024632-6edf-4ba1-8e59-9672ba7f7f43" type="Noun">
          <Vi>phiếu bầu; cuộc bầu cử</Vi>
          <En>A formal indication of choice, typically in a political election or decision-making process.</En>
          <Example>We cast our votes at the local polling station.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="176ff444-94f2-4e75-8c15-7bb2a34f046b">
              <Vi>Người dân đi bỏ phiếu trong ngày bầu cử quốc hội.</Vi>
              <En>Citizens go to polling stations to vote in a national election.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="e1e2ca58-8244-4d21-85b5-c53086a77ba8" type="Verb">
          <Vi>bỏ phiếu; biểu quyết</Vi>
          <En>To express a choice or preference in an election or decision-making process.</En>
          <Example>The committee voted unanimously to approve the proposal.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="8ac3f581-b0d5-4956-862b-9ff461cddab0">
              <Vi>Ban giám hiệu đang biểu quyết về việc tăng học phí.</Vi>
              <En>The faculty is voting on whether to raise tuition fees.</En>
            </Situation>
          </Situations>
        </Meaning>
