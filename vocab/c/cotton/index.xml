      <Meanings>
        <Meaning id="d05299c1-a3e4-4d36-8ae2-a7e247d667af" type="Noun">
          <Vi>bông (sợi thực vật); vải bông</Vi>
          <En>The soft, fluffy fiber that grows in the seed pod of the cotton plant, or fabric made from this fiber.</En>
          <Example>She wore a comfortable cotton shirt on the hot summer day.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="cc173df0-defd-40de-893a-874b903a054f">
              <Vi>Mô tả sợi bông tự nhiên hoặc sản phẩm dệt từ sợi bông.</Vi>
              <En>Refers to natural cotton fiber or fabric made from it.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="0413cb93-2986-477a-b340-6c93d9412729" type="Verb">
          <Vi>thu hoạch bông; dệt bằng vải bông</Vi>
          <En>To harvest cotton; or (less commonly) to make or wear cotton fabric.</En>
          <Example>The farmers began to cotton in early autumn.</Example>
          <IsArchaic>true</IsArchaic>
          <Situations>
            <Situation id="bb8bf7ee-1ae0-4dec-a891-508b293dd284">
              <Vi>Ngành nông nghiệp: thu hoạch bông vào mùa vụ.</Vi>
              <En>Agriculture: harvesting cotton during the harvest season.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
