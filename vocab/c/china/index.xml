        <Meaning id="6a214066-4103-45bf-9ccc-5a7a9f1a7d3e" type="Noun">
          <Vi>Trung Quốc</Vi>
          <En>A country in East Asia, the world’s most populous nation, officially known as the People’s Republic of China.</En>
          <Example>Beijing is the capital city of China.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="108555a4-6858-4e2b-b688-48bfb1580746">
