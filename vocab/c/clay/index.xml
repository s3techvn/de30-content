      <Meanings>
        <Meaning id="75879a2e-db55-4add-8f4f-599f2e160db9" type="Noun">
          <Vi>Đất sét</Vi>
          <En>Soft, sticky earth that becomes hard when dried or heated; a fine-grained natural soil material.</En>
          <Example>She molded the clay into a beautiful vase.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="7dcfec74-ba99-4b3d-b4aa-fd14c39e80d5">
              <Vi>Người làm gốm nhào nặn đất sét để tạo hình.</Vi>
              <En>A potter kneads clay to shape pottery.</En>
            </Situation>
            <Situation id="688732c0-51cc-41e3-91fc-8fa03072240d">
              <Vi>Đất sét ẩm thường xuất hiện sau mưa lớn.</Vi>
              <En>Wet clay often appears after heavy rain.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="cb13e795-1124-47da-b345-d30136c6ea85" type="Noun">
          <Vi>Đất sét (trong nghĩa ẩn dụ: người uỷ nhiệm, người phụ thuộc)</Vi>
          <En>Figuratively: a person who is easily influenced or controlled by others.</En>
          <Example>He was like clay in her hands—easily shaped by her suggestions.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="a53d246d-2acd-4c58-bf5c-f35d78b39797">
              <Vi>Cô ấy đối xử với đồng nghiệp như đất sét trong tay người tạo hình.</Vi>
              <En>She treated her colleagues like clay in her hands—malleable and moldable.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
