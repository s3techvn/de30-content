      <Meanings>
        <Meaning id="b11197fd-dbe1-495a-9d76-a182f66eb188" type="Adjective">
          <Vi>đóng kín; không mở</Vi>
          <En>not open; having an opening or entrance that is shut or sealed.</En>
          <Example>The shop is closed on Sundays.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="77413c81-1db8-4b75-8cc4-877ab92b03f1">
              <Vi>Mô tả một cửa hàng, nhà, hoặc hộp không còn mở.</Vi>
              <En>Describing a shop, house, or box that is not open.</En>
            </Situation>
            <Situation id="f44bf11d-fb90-41c7-bbf4-dfa3334cb374">
              <Vi>Chỉ trạng thái không còn hoạt động (ví dụ: tài khoản, thị trường).</Vi>
              <En>Referring to a state of no longer being active (e.g., account, market).</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="9ce79110-d605-4794-b566-79aa8136948c" type="Adjective">
          <Vi>khép kín; không cởi mở</Vi>
          <En>not open to new ideas, opinions, or experiences; rigid or narrow-minded.</En>
          <Example>He has a very closed mind about alternative medicine.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="076283ad-77b9-45b6-8d7b-9c3acaecda9a">
              <Vi>Mô tả một người không sẵn sàng tiếp nhận ý kiến mới.</Vi>
              <En>Describing a person unwilling to accept new ideas or perspectives.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
