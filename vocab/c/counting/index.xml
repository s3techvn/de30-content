      <Meanings>
        <Meaning id="c119a602-3ff4-4d8f-94c1-3c02e50f270e" type="Noun">
          <Vi>việc đếm, sự đếm</Vi>
          <En>The action or process of determining the total number of items in a set.</En>
          <Example>Counting the students in the classroom takes just a few minutes.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="9cf1a7bd-3834-41ab-b486-b97c49870a93">
              <Vi>Giáo viên đang đếm số học sinh trong lớp để kiểm tra sĩ số.</Vi>
              <En>The teacher is counting the students in the class for attendance.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="3acad62c-a324-4bc5-9896-773dea987846" type="Verb">
          <Vi>đếm (hành động)</Vi>
          <En>To determine the number or amount of something by listing or calculating them.</En>
          <Example>She started counting the coins in her piggy bank.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="133a294b-4688-4abc-935d-9c3ca0dfa737">
              <Vi>Trẻ em học cách đếm các ngón tay từ 1 đến 10.</Vi>
              <En>A child is learning to count fingers from 1 to 10.</En>
            </Situation>
          </Situations>
        </Meaning>
