      <Meanings>
        <Meaning id="9e930cb8-f9c8-4c5b-b3f3-a056dd8d1b9b" type="Noun">
          <Vi>Cộng đồng</Vi>
          <En>A group of people living in the same place or having a particular characteristic in common.</En>
          <Example>The local community organized a clean-up day for the park.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="d5c0cdec-9f7d-481f-bf8b-8e515ab280cd">
              <Vi>Một nhóm người sinh sống gần nhau và tương tác thường xuyên.</Vi>
              <En>A group of people who live near each other and interact regularly.</En>
            </Situation>
            <Situation id="7213160b-2cf7-4929-b070-0f6516cac24f">
              <Vi>Một nhóm người chia sẻ sở thích, giá trị, hoặc mục tiêu chung (ví dụ: cộng đồng người yêu thích mã nguồn mở).</Vi>
              <En>A group of people who share interests, values, or goals (e.g., the open-source community).</En>
            </Situation>
          </Situations>
        </Meaning>
