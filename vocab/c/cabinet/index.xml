      <Meanings>
        <Meaning id="ad77c189-4c97-4f23-aaee-c7a6af52afc3" type="Noun">
          <Vi>Bộ trưởng (trong nội các)</Vi>
          <En>A group of senior government ministers, typically headed by a prime minister or president, who collectively make key policy decisions.</En>
          <Example>The cabinet met behind closed doors to discuss the new economic policy.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="a12536ac-1755-40e4-b901-27bcfacf4181">
              <Vi>Các bộ trưởng họp nội các để thông qua quyết định quan trọng.</Vi>
              <En>Senior ministers gather to deliberate and approve major national policies.</En>
            </Situation>
          </Situations>
        </Meaning>
        <Meaning id="e0aa5261-7a4d-444d-a9f7-4278d53d9582" type="Noun">
          <Vi>Tủ (đựng đồ, sách, đồ dùng…)</Vi>
          <En>A piece of furniture with shelves, drawers, or compartments for storing or displaying items.</En>
          <Example>She kept her spices in a small cabinet near the stove.</Example>
          <IsArchaic>false</IsArchaic>
          <Situations>
            <Situation id="a3e3678a-3c02-406e-aae7-ecf0094a2d23">
              <Vi>Tủ chứa đồ dùng trong nhà bếp hoặc phòng khách.</Vi>
              <En>A storage unit used in kitchens or living rooms to hold everyday items.</En>
            </Situation>
          </Situations>
        </Meaning>
      </Meanings>
